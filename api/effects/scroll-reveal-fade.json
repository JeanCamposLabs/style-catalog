  "ai_usage": "The standard scroll-entrance for marketing pages. Give items class .reveal (opacity:0; translateY). Create one IntersectionObserver, observe all .reveal nodes, and add .in on intersection (optionally unobserve to fire once). Stagger with transition-delay tied to index. ALWAYS short-circuit to the visible state under prefers-reduced-motion. The demo auto-scrolls so the effect is visible in the catalog frame.",
  "path": "effects/transitions-animations/scroll-reveal-fade.html",
  "source": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>Scroll Reveal Fade-Up</title>\n  <script type=\"application/json\" id=\"effect-meta\">\n  {\n    \"id\": \"scroll-reveal-fade\",\n    \"title\": \"Scroll Reveal Fade-Up\",\n    \"summary\": \"Elements fade and slide up as they enter the viewport, via IntersectionObserver.\",\n    \"description\": \"Items start hidden (opacity 0, translateY); an IntersectionObserver adds an 'in' class when they scroll into view, triggering a CSS transition. The web-standard, dependency-free replacement for scroll libraries.\",\n    \"theme\": \"transitions-animations\",\n    \"categories\": [\"animation\", \"scroll\", \"reveal\"],\n    \"tags\": [\"scroll\", \"reveal\", \"fade\", \"intersection-observer\", \"entrance\", \"stagger\"],\n    \"tech\": [\"css\", \"js\"],\n    \"era\": \"2020s\",\n    \"difficulty\": \"intermediate\",\n    \"dependencies\": [],\n    \"browser_support\": \"All modern browsers (IntersectionObserver universally supported).\",\n    \"performance_notes\": \"Far cheaper than scroll-event listeners; the observer fires only at thresholds. Transition animates opacity/transform.\",\n    \"accessibility_notes\": \"Content is in the DOM and accessible regardless of reveal state. Under prefers-reduced-motion, show everything immediately (no transform).\",\n    \"customization\": [\n      { \"name\": \"--rise\", \"description\": \"Distance items travel up\", \"default\": \"24px\" },\n      { \"name\": \"threshold\", \"description\": \"How much must be visible to trigger\", \"default\": \"0.15\" }\n    ],\n    \"variations\": [\"Fade from left/right\", \"Scale-in\", \"Stagger via transition-delay per index\"],\n    \"related\": [\"text-reveal-mask\"],\n    \"ai_usage\": \"The standard scroll-entrance for marketing pages. Give items class .reveal (opacity:0; translateY). Create one IntersectionObserver, observe all .reveal nodes, and add .in on intersection (optionally unobserve to fire once). Stagger with transition-delay tied to index. ALWAYS short-circuit to the visible state under prefers-reduced-motion. The demo auto-scrolls so the effect is visible in the catalog frame.\"\n  }\n  </script>\n  <style>\n    :root { --rise: 24px; }\n    * { box-sizing: border-box; }\n    html, body { margin: 0; }\n    body { background: #0b0d12; font-family: system-ui, sans-serif; color: #e7ebf3; }\n    .scroller { height: 100vh; overflow-y: auto; padding: 1rem; }\n    .block { height: 80px; margin: 18px auto; max-width: 300px; border-radius: 12px;\n      display: grid; place-items: center; background: #151925; border: 1px solid #262c3d; }\n    .reveal { opacity: 0; transform: translateY(var(--rise)); transition: opacity .6s ease, transform .6s ease; }\n    .reveal.in { opacity: 1; transform: translateY(0); }\n    .spacer { height: 30vh; }\n    @media (prefers-reduced-motion: reduce) { .reveal { opacity: 1; transform: none; transition: none; } }\n  </style>\n</head>\n<body>\n  <div class=\"scroller\" id=\"scroller\">\n    <div class=\"spacer\"></div>\n    <div class=\"block reveal\">Reveal 1</div>\n    <div class=\"block reveal\">Reveal 2</div>\n    <div class=\"block reveal\">Reveal 3</div>\n    <div class=\"block reveal\">Reveal 4</div>\n    <div class=\"block reveal\">Reveal 5</div>\n    <div class=\"spacer\"></div>\n  </div>\n  <script>\n    var root = document.getElementById(\"scroller\");\n    var io = new IntersectionObserver(function (entries) {\n      entries.forEach(function (e) { if (e.isIntersecting) { e.target.classList.add(\"in\"); io.unobserve(e.target); } });\n    }, { root: root, threshold: 0.15 });\n    document.querySelectorAll(\".reveal\").forEach(function (el) { io.observe(el); });\n    // Auto-demo: gently scroll so the reveal is visible inside the catalog iframe.\n    if (!matchMedia(\"(prefers-reduced-motion: reduce)\").matches) {\n      var dir = 1;\n      setInterval(function () {\n        root.scrollTop += dir * 2;\n        if (root.scrollTop + root.clientHeight >= root.scrollHeight - 2) dir = -1;\n        if (root.scrollTop <= 0) dir = 1;\n      }, 16);\n    }\n  </script>\n</body>\n</html>\n"
}
