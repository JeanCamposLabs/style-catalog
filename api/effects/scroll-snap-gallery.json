  "ai_usage": "Use for image carousels, onboarding slides, and full-page section snapping. Container: overflow-x:auto; scroll-snap-type: x mandatory; flex row. Each slide: flex:0 0 <width>; scroll-snap-align: start (or center). Use 'proximity' instead of 'mandatory' if mandatory feels too aggressive. Add prev/next buttons calling scrollBy for a fuller carousel; native scroll already gives touch/keyboard support.",
  "path": "effects/scroll-effects/scroll-snap-gallery.html",
  "source": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>Scroll Snap Gallery</title>\n  <script type=\"application/json\" id=\"effect-meta\">\n  {\n    \"id\": \"scroll-snap-gallery\",\n    \"title\": \"Scroll Snap Gallery\",\n    \"summary\": \"A horizontal gallery where each slide snaps cleanly into place — pure CSS scroll-snap.\",\n    \"description\": \"Uses scroll-snap-type on a horizontally-scrolling container and scroll-snap-align on children so swiping/scrolling locks each slide to the start, a native carousel with no JS.\",\n    \"theme\": \"scroll-effects\",\n    \"categories\": [\"scroll\", \"carousel\", \"gallery\"],\n    \"tags\": [\"scroll-snap\", \"carousel\", \"gallery\", \"horizontal\", \"swipe\", \"slides\"],\n    \"tech\": [\"css\"],\n    \"era\": \"2020s\",\n    \"difficulty\": \"beginner\",\n    \"dependencies\": [],\n    \"browser_support\": \"All modern browsers (CSS scroll-snap).\",\n    \"performance_notes\": \"Native scrolling; very smooth and JS-free.\",\n    \"accessibility_notes\": \"Keep slides keyboard-scrollable and focusable; native scroll handles touch/trackpad. For a true carousel add labels and optional prev/next buttons. Snap doesn't trap focus.\",\n    \"customization\": [\n      { \"name\": \"scroll-snap-type\", \"description\": \"Axis + strictness (mandatory/proximity)\", \"default\": \"x mandatory\" },\n      { \"name\": \"slide width\", \"description\": \"Per-slide flex-basis\", \"default\": \"80%\" }\n    ],\n    \"variations\": [\"Vertical snap (full-page sections)\", \"Center-aligned snap\", \"Snap with peeking next slide\"],\n    \"related\": [\"sticky-stack-cards\", \"carousel-3d\"],\n    \"ai_usage\": \"Use for image carousels, onboarding slides, and full-page section snapping. Container: overflow-x:auto; scroll-snap-type: x mandatory; flex row. Each slide: flex:0 0 <width>; scroll-snap-align: start (or center). Use 'proximity' instead of 'mandatory' if mandatory feels too aggressive. Add prev/next buttons calling scrollBy for a fuller carousel; native scroll already gives touch/keyboard support.\"\n  }\n  </script>\n  <style>\n    * { box-sizing: border-box; }\n    html, body { height: 100%; margin: 0; }\n    body { display: grid; place-items: center; background: #0b0d12; font-family: system-ui, sans-serif; }\n    .snap {\n      display: flex; gap: 1rem; width: 320px; padding: 1rem; overflow-x: auto;\n      scroll-snap-type: x mandatory; scrollbar-width: thin;\n    }\n    .slide {\n      flex: 0 0 80%; height: 200px; border-radius: 16px; scroll-snap-align: center;\n      display: grid; place-items: center; color: #fff; font-size: 2rem; font-weight: 800;\n    }\n    .s1 { background: linear-gradient(135deg,#7c5cff,#5b3ee0); }\n    .s2 { background: linear-gradient(135deg,#2dd4bf,#0ea5a5); }\n    .s3 { background: linear-gradient(135deg,#f0abfc,#c026d3); }\n    .s4 { background: linear-gradient(135deg,#fb7185,#e11d48); }\n  </style>\n</head>\n<body>\n  <div class=\"snap\">\n    <div class=\"slide s1\">1</div>\n    <div class=\"slide s2\">2</div>\n    <div class=\"slide s3\">3</div>\n    <div class=\"slide s4\">4</div>\n  </div>\n</body>\n</html>\n"
}
