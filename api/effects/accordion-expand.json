  "tech": [
    "css"
  ],
  "era": "2020s",
  "difficulty": "intermediate",
  "dependencies": [],
  "browser_support": "Modern browsers; the 0fr→1fr grid animation works in current Chromium/Firefox/Safari. Older browsers simply jump (acceptable).",
  "performance_notes": "Animates grid-template-rows; the content wrapper must be overflow:hidden. No JS needed for toggle (native details).",
  "accessibility_notes": "Built on <details>/<summary>, so it's keyboard-operable and announced as a disclosure out of the box — no ARIA needed. Honors prefers-reduced-motion.",
