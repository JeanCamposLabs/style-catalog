  "source": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>SaaS Landing Page</title>\n  <script type=\"application/json\" id=\"effect-meta\">\n  {\n    \"id\": \"saas-landing\",\n    \"title\": \"SaaS Landing Page\",\n    \"summary\": \"A complete modern SaaS landing: sticky nav, gradient hero, logo strip, bento features, pricing, and footer.\",\n    \"description\": \"A full, self-contained landing-page scaffold in the current SaaS idiom — token-driven colors, a gradient hero with dual CTAs, a social-proof logo row, a bento feature grid, a three-tier pricing block with a highlighted plan, and a footer.\",\n    \"theme\": \"website-templates\",\n    \"categories\": [\"template\", \"landing\", \"marketing\"],\n    \"tags\": [\"saas\", \"landing-page\", \"marketing\", \"hero\", \"pricing\", \"bento\", \"full-page\"],\n    \"tech\": [\"css\", \"html\"],\n    \"era\": \"2020s\",\n    \"difficulty\": \"intermediate\",\n    \"dependencies\": [],\n    \"browser_support\": \"All modern browsers.\",\n    \"performance_notes\": \"Pure HTML/CSS, no images (gradient placeholders), no JS. Loads instantly.\",\n    \"accessibility_notes\": \"Semantic landmarks (header/nav/main/section/footer), real headings hierarchy, focus-visible rings on CTAs, sufficient contrast on the dark theme.\",\n    \"customization\": [\n      { \"name\": \"--accent / --accent-2\", \"description\": \"Brand gradient\", \"default\": \"#7c5cff / #2dd4bf\" },\n      { \"name\": \"content regions\", \"description\": \"Headlines, features, prices, links — replace the placeholder copy\", \"default\": \"edit markup\" }\n    ],\n    \"variations\": [\"Light theme (swap the token block)\", \"Add testimonials / FAQ sections\", \"Swap bento for a 3-column feature row\"],\n    \"related\": [\"hero-section\", \"pricing-card\", \"glass-navbar\"],\n    \"ai_usage\": \"Use as a starting scaffold for a product/SaaS marketing site. Copy the whole document. Reskin by editing the :root tokens (colors, radius) and replacing the text in each <section>. Sections are independent — delete or reorder freely. Replace gradient placeholder tiles with real screenshots/illustrations. The layout is responsive via auto-fit grids; keep the semantic landmarks and heading order. No build step or dependencies required.\"\n  }\n  </script>\n  <style>\n    :root { --accent:#7c5cff; --accent-2:#2dd4bf; --bg:#0b0d12; --surface:#11141c; --line:#222838; --text:#e7ebf3; --muted:#8b93a7; --radius:16px; }\n    *{box-sizing:border-box;} html,body{margin:0;}\n    body{background:var(--bg);color:var(--text);font-family:system-ui,-apple-system,\"Segoe UI\",sans-serif;line-height:1.5;}\n    a{color:inherit;text-decoration:none;}\n    .wrap{max-width:1100px;margin:0 auto;padding:0 1.2rem;}\n    header{position:sticky;top:0;z-index:10;background:rgba(11,13,18,.8);backdrop-filter:blur(10px);border-bottom:1px solid var(--line);}\n    .nav{display:flex;align-items:center;justify-content:space-between;height:62px;}\n    .brand{font-weight:800;font-size:1.15rem;}\n    .brand span{background:linear-gradient(120deg,var(--accent),var(--accent-2));-webkit-background-clip:text;background-clip:text;color:transparent;}\n    .nav ul{display:flex;gap:1.4rem;list-style:none;margin:0;padding:0;color:var(--muted);font-size:.92rem;}\n    .nav .cta{background:var(--accent);color:#fff;padding:.5rem 1rem;border-radius:10px;font-weight:600;}\n    .hero{text-align:center;padding:5rem 0 4rem;position:relative;overflow:hidden;}\n    .hero::before{content:\"\";position:absolute;width:60vmax;height:60vmax;left:50%;top:-30vmax;transform:translateX(-50%);\n      background:radial-gradient(circle,rgba(124,92,255,.35),transparent 60%);filter:blur(20px);pointer-events:none;}\n    .eyebrow{color:var(--accent-2);font-weight:700;letter-spacing:.14em;text-transform:uppercase;font-size:.78rem;}\n    .hero h1{font-size:clamp(2.2rem,6vw,3.8rem);margin:.6rem 0;line-height:1.05;font-weight:900;}\n    .hero p{color:var(--muted);font-size:1.15rem;max-width:560px;margin:0 auto 1.8rem;}\n    .btns{display:flex;gap:.8rem;justify-content:center;flex-wrap:wrap;}\n    .btn{padding:.85rem 1.6rem;border-radius:12px;font-weight:700;border:1px solid transparent;}\n    .btn-primary{background:linear-gradient(120deg,var(--accent),var(--accent-2));color:#fff;}\n    .btn-ghost{border-color:var(--line);color:var(--text);}\n    .btn:focus-visible{outline:3px solid var(--accent-2);outline-offset:2px;}\n    .logos{display:flex;gap:2rem;justify-content:center;flex-wrap:wrap;opacity:.6;padding:2rem 0;color:var(--muted);font-weight:700;}\n    .section{padding:3.5rem 0;}\n    .section h2{text-align:center;font-size:2rem;margin:0 0 2rem;}\n    .bento{display:grid;grid-template-columns:repeat(4,1fr);grid-auto-rows:120px;gap:1rem;}\n    .tile{background:var(--surface);border:1px solid var(--line);border-radius:var(--radius);padding:1.2rem;display:flex;flex-direction:column;justify-content:flex-end;}\n    .tile h3{margin:0 0 .2rem;} .tile p{margin:0;color:var(--muted);font-size:.88rem;}\n    .tile.big{grid-column:span 2;grid-row:span 2;background:linear-gradient(160deg,rgba(124,92,255,.25),var(--surface));}\n    .tile.wide{grid-column:span 2;}\n    .pricing{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:1.2rem;}\n    .plan{background:var(--surface);border:1px solid var(--line);border-radius:var(--radius);padding:1.6rem;}\n    .plan.featured{border-color:transparent;background:linear-gradient(var(--surface),var(--surface)) padding-box,linear-gradient(135deg,var(--accent),var(--accent-2)) border-box;}\n    .plan .price{font-size:2.4rem;font-weight:900;margin:.4rem 0;}\n    .plan ul{list-style:none;padding:0;margin:1rem 0;color:var(--muted);}\n    .plan li{padding:.3rem 0;} .plan li::before{content:\"✓ \";color:var(--accent-2);}\n    footer{border-top:1px solid var(--line);color:var(--muted);padding:2rem 0;text-align:center;font-size:.9rem;}\n    @media(max-width:720px){.bento{grid-template-columns:repeat(2,1fr);}.tile.big{grid-column:span 2;}.nav ul li:not(:last-child){display:none;}}\n  </style>\n</head>\n<body>\n  <header><div class=\"wrap nav\">\n    <div class=\"brand\">◆ <span>Nimbus</span></div>\n    <ul><li>Product</li><li>Features</li><li>Pricing</li><li>Docs</li><li><a class=\"cta\" href=\"#\">Start free</a></li></ul>\n  </div></header>\n\n  <main>\n    <section class=\"hero\"><div class=\"wrap\">\n      <p class=\"eyebrow\">New · v2 is here</p>\n      <h1>Ship products your users love.</h1>\n      <p>The all-in-one platform to build, launch, and scale — without the busywork.</p>\n      <div class=\"btns\"><a class=\"btn btn-primary\" href=\"#\">Start free trial</a><a class=\"btn btn-ghost\" href=\"#\">Book a demo</a></div>\n    </div></section>\n\n    <div class=\"wrap\"><div class=\"logos\"><span>ACME</span><span>Globex</span><span>Umbrella</span><span>Initech</span><span>Hooli</span></div></div>\n\n    <section class=\"section\"><div class=\"wrap\">\n      <h2>Everything you need</h2>\n      <div class=\"bento\">\n        <div class=\"tile big\"><h3>Realtime analytics</h3><p>See what matters as it happens.</p></div>\n        <div class=\"tile\"><h3>Fast</h3><p>Edge-deployed.</p></div>\n        <div class=\"tile\"><h3>Secure</h3><p>SOC2-ready.</p></div>\n        <div class=\"tile wide\"><h3>Integrations</h3><p>100+ connectors out of the box.</p></div>\n        <div class=\"tile\"><h3>Teams</h3><p>Collaborate live.</p></div>\n        <div class=\"tile\"><h3>API</h3><p>Build anything.</p></div>\n      </div>\n    </div></section>\n\n    <section class=\"section\"><div class=\"wrap\">\n      <h2>Simple pricing</h2>\n      <div class=\"pricing\">\n        <div class=\"plan\"><h3>Starter</h3><div class=\"price\">$0</div><ul><li>1 project</li><li>Community support</li></ul><a class=\"btn btn-ghost\" href=\"#\">Get started</a></div>\n        <div class=\"plan featured\"><h3>Pro</h3><div class=\"price\">$29</div><ul><li>Unlimited projects</li><li>Priority support</li><li>Advanced analytics</li></ul><a class=\"btn btn-primary\" href=\"#\">Choose Pro</a></div>\n        <div class=\"plan\"><h3>Enterprise</h3><div class=\"price\">Custom</div><ul><li>SSO & SAML</li><li>Dedicated SLA</li></ul><a class=\"btn btn-ghost\" href=\"#\">Contact us</a></div>\n      </div>\n    </div></section>\n  </main>\n\n  <footer><div class=\"wrap\">© 2026 Nimbus, Inc. · Privacy · Terms · Status</div></footer>\n</body>\n</html>\n"
}
