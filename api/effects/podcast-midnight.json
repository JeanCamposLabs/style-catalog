  "source": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n<title>Podcast — Midnight</title>\n<script type=\"application/json\" id=\"effect-meta\">\n{\n  \"id\": \"podcast-midnight\",\n  \"title\": \"Podcast — Midnight\",\n  \"summary\": \"A premium, self-contained podcast landing page in the Midnight style, with catalog effects (animated gradient, glass nav, scroll-reveal, card-lift, scroll-progress, gradient text) baked in.\",\n  \"description\": \"Full-page Podcast template — “Conversations worth your time.”. Sticky glass nav, animated hero, 5 sections, and a footer, all in one file. Recolor via the :root tokens; replace the marked content. Part of a generated family spanning 12 palettes.\",\n  \"theme\": \"website-templates\",\n  \"categories\": [\n    \"template\",\n    \"creator\"\n  ],\n  \"tags\": [\n    \"template\",\n    \"full-page\",\n    \"podcast\",\n    \"creator\",\n    \"midnight\",\n    \"responsive\",\n    \"effects\"\n  ],\n  \"tech\": [\n    \"html\",\n    \"css\",\n    \"js\"\n  ],\n  \"era\": \"2020s\",\n  \"difficulty\": \"intermediate\",\n  \"dependencies\": [],\n  \"browser_support\": \"All modern browsers.\",\n  \"performance_notes\": \"Pure HTML/CSS + a few lines of vanilla JS (scroll-progress, IntersectionObserver reveals). No images or libraries.\",\n  \"accessibility_notes\": \"Semantic landmarks, real headings/links/forms, focus-visible rings, and a prefers-reduced-motion guard that disables animation and reveals.\",\n  \"customization\": [\n    {\n      \"name\": \":root tokens\",\n      \"description\": \"Palette colors, radius, fonts\",\n      \"default\": \"Midnight palette\"\n    },\n    {\n      \"name\": \"content regions\",\n      \"description\": \"Brand, headline, features, prices, copy\",\n      \"default\": \"edit markup\"\n    }\n  ],\n  \"variations\": [\n    \"Same template in other palettes (midnight, aurora, glass, neon, forest, ocean, paper, mono, pastel, sunset, corporate, brutalist)\",\n    \"Reorder or drop sections\",\n    \"Swap gradient placeholders for real images\"\n  ],\n  \"related\": [\n    \"animated-gradient\",\n    \"glass-navbar\",\n    \"card-lift\",\n    \"reveal-on-scroll\",\n    \"scroll-progress-bar\",\n    \"gradient-text\"\n  ],\n  \"ai_usage\": \"Use as a ready-to-ship Podcast page. Copy the whole file; reskin by editing the :root custom properties (colors/radius/font) and replacing the content in each <section>. Sections are independent — reorder or delete freely. It composes catalog effects inline (animated gradient hero, glassmorphic sticky nav, scroll-triggered reveals, card hover-lift, a scroll-progress bar, and gradient text) so you get a premium feel with zero dependencies. Replace the gradient placeholder blocks with real <img> (add alt text). Responsive and reduced-motion safe out of the box.\"\n}\n</script>\n<style>\n*{box-sizing:border-box}html{scroll-behavior:smooth}\nbody{margin:0;background:#0b0d12;color:#e8ecf6;font-family:system-ui,-apple-system,Segoe UI,sans-serif;line-height:1.6;-webkit-font-smoothing:antialiased}\nimg{max-width:100%}a{color:inherit;text-decoration:none}\n.wrap{max-width:1140px;margin:0 auto;padding:0 1.3rem}\nh1,h2,h3{line-height:1.1;margin:0 0 .5rem}\nh1{font-size:clamp(2.2rem,6vw,4rem);font-weight:800}\nh2{font-size:clamp(1.7rem,3.6vw,2.6rem);font-weight:800}\np{margin:0 0 1rem}\n.grad{background:linear-gradient(120deg,#7c5cff,#2dd4bf);-webkit-background-clip:text;background-clip:text;color:transparent}\n.eyebrow{font-size:.78rem;letter-spacing:.16em;text-transform:uppercase;font-weight:700;color:#2dd4bf}\n.muted{color:#8b93a7}\n.prog{position:fixed;top:0;left:0;height:3px;width:0;background:linear-gradient(120deg,#7c5cff,#2dd4bf);z-index:99}\nnav.bar{position:sticky;top:0;z-index:40;border-bottom:1px solid #242a3b;background:#0b0d12cc;backdrop-filter:blur(12px)}\nnav.bar .wrap{display:flex;align-items:center;justify-content:space-between;height:64px}\n.brand{font-weight:900;font-size:1.15rem;display:flex;align-items:center;gap:.5rem}\n.brand .dot{width:22px;height:22px;border-radius:7px;background:linear-gradient(120deg,#7c5cff,#2dd4bf);display:inline-block}\n.navlinks{display:flex;gap:1.5rem;align-items:center}\n.navlinks a{color:#8b93a7;font-size:.92rem;font-weight:600}\n.navlinks a:hover{color:#e8ecf6}\n.btn{display:inline-block;cursor:pointer;font-weight:700;border-radius:16px;padding:.78rem 1.5rem;border:1px solid transparent;background:linear-gradient(120deg,#7c5cff,#2dd4bf);color:#fff;transition:transform .12s,box-shadow .12s,filter .12s;}\n.btn:hover{transform:translateY(-2px);filter:brightness(1.06);box-shadow:0 10px 24px rgba(0,0,0,.5)}\n.btn.ghost{background:transparent;color:#e8ecf6;border:1px solid #242a3b}\n.btn:focus-visible,.navlinks a:focus-visible{outline:3px solid #2dd4bf;outline-offset:2px}\n.sec{padding:clamp(3rem,7vw,5.5rem) 0}\n.sec.tint{background:#161a26}\n.center{text-align:center}.lead{max-width:60ch;margin-inline:auto;font-size:1.12rem}\n.grid{display:grid;gap:1.2rem}\n.card{background:#11141c;border:1px solid #242a3b;border-radius:16px;padding:1.4rem;box-shadow:0 12px 40px rgba(0,0,0,.45);transition:transform .18s,box-shadow .18s}\n.card.lift:hover{transform:translateY(-7px)}\n.ph{border-radius:16px;aspect-ratio:16/10;display:block}\n.tag{display:inline-block;font-size:.75rem;padding:.2rem .6rem;border-radius:999px;background:#161a26;color:#8b93a7;border:1px solid #242a3b}\n.reveal{opacity:0;transform:translateY(22px);transition:opacity .7s ease,transform .7s cubic-bezier(.2,.8,.2,1)}\n.reveal.in{opacity:1;transform:none}\n.kpi{font-size:clamp(2rem,5vw,3.2rem);font-weight:900;}\ndetails{border-top:1px solid #242a3b;padding:1rem 0}details summary{cursor:pointer;font-weight:700;list-style:none;display:flex;justify-content:space-between}\ndetails summary::-webkit-details-marker{display:none}details[open] summary{color:#2dd4bf}\nfooter.ft{border-top:1px solid #242a3b;background:#161a26}\nfooter.ft .wrap{padding:2.4rem 1.3rem}\n.fcols{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:1.5rem}\n.fcols a{display:block;color:#8b93a7;padding:.2rem 0;font-size:.9rem}\n.hero-bg{position:relative;overflow:hidden}\n.hero-bg::before{content:\"\";position:absolute;inset:-30% -10% auto;height:70vmax;background:radial-gradient(closest-side,#7c5cff40,transparent 70%),radial-gradient(closest-side,#2dd4bf33,transparent 70%);background-position:30% 0,80% 10%;background-repeat:no-repeat;filter:blur(10px);animation:float 16s ease-in-out infinite;pointer-events:none}\n@keyframes float{50%{transform:translateY(40px) scale(1.05)}}\n@media(max-width:820px){.navlinks{display:none}.fcols{grid-template-columns:1fr 1fr}}\n@media(prefers-reduced-motion:reduce){*{animation:none!important;scroll-behavior:auto}.reveal{opacity:1;transform:none;transition:none}.hero-bg::before{animation:none}}\n</style>\n</head>\n<body>\n<div class=\"prog\"></div>\n<nav class=\"bar\"><div class=\"wrap\">\n    <a class=\"brand\" href=\"#\"><span class=\"dot\"></span>The Long Game</a>\n    <div class=\"navlinks\"><a href=\"#\">Episodes</a><a href=\"#\">About</a><a href=\"#\">Guests</a><a href=\"#\">Subscribe</a><a class=\"btn\" href=\"#\">Listen now</a></div>\n  </div></nav>\n<header class=\"sec hero-bg\"><div class=\"wrap\" style=\"display:grid;grid-template-columns:1.1fr 1fr;gap:2.4rem;align-items:center\">\n    <div><p class=\"eyebrow reveal\">New episodes weekly</p><h1 class=\"reveal\">Conversations <span class=\"grad\">worth your time</span>.</h1>\n      <p class=\"muted reveal\" style=\"font-size:1.12rem;max-width:46ch\">Deep talks with the people quietly shaping the future, one idea at a time.</p>\n      <div class=\"reveal\" style=\"display:flex;gap:.8rem;flex-wrap:wrap;margin-top:1.2rem\"><a class=\"btn\" href=\"#\">Listen now</a><a class=\"btn ghost\" href=\"#\">All episodes</a></div>\n    </div>\n    <div class=\"ph reveal\" style=\"aspect-ratio:4/5;background:linear-gradient(135deg,#2dd4bf,#7c5cff)\"></div>\n  </div><style>@media(max-width:820px){header.sec .wrap{grid-template-columns:1fr!important}}</style></header>\n<section class=\"sec\"><div class=\"wrap\">\n    <div class=\"center reveal\"><p class=\"eyebrow\">How it works</p><h2>Three simple steps</h2></div>\n    <div class=\"grid reveal\" style=\"grid-template-columns:repeat(auto-fit,minmax(240px,1fr));margin-top:2rem\">\n      <div class=\"card\"><div class=\"grad kpi\" style=\"font-size:2rem\">01</div><h3>Sign up</h3><p class=\"muted\">Create your account in seconds.</p></div><div class=\"card\"><div class=\"grad kpi\" style=\"font-size:2rem\">02</div><h3>Customize</h3><p class=\"muted\">Make it yours with a few clicks.</p></div><div class=\"card\"><div class=\"grad kpi\" style=\"font-size:2rem\">03</div><h3>Launch</h3><p class=\"muted\">Go live and start growing.</p></div>\n    </div></div></section>\n<section class=\"sec tint\"><div class=\"wrap grid reveal\" style=\"grid-template-columns:repeat(auto-fit,minmax(160px,1fr));text-align:center\">\n    <div><div class=\"kpi grad\">10k+</div><div class=\"muted\">Customers</div></div><div><div class=\"kpi grad\">99.9%</div><div class=\"muted\">Uptime</div></div><div><div class=\"kpi grad\">4.9/5</div><div class=\"muted\">Rating</div></div><div><div class=\"kpi grad\">120+</div><div class=\"muted\">Countries</div></div>\n  </div></section>\n<section class=\"sec tint\"><div class=\"wrap center\" style=\"max-width:560px\">\n    <h2 class=\"reveal\">Stay in the loop</h2><p class=\"muted reveal\">One thoughtful email a week. No spam, ever.</p>\n    <form class=\"reveal\" onsubmit=\"event.preventDefault();this.querySelector('input').value='';this.nextElementSibling.textContent='Thanks — you are subscribed!'\" style=\"display:flex;gap:.5rem;justify-content:center;flex-wrap:wrap;margin-top:1rem\">\n      <input type=\"email\" required placeholder=\"you@example.com\" style=\"flex:1;min-width:200px;padding:.8rem 1rem;border-radius:16px;border:1px solid #242a3b;background:#11141c;color:#e8ecf6\"><button class=\"btn\" type=\"submit\">Subscribe</button>\n    </form><p class=\"muted\" role=\"status\" style=\"min-height:1.2em;margin-top:.6rem\"></p>\n  </div></section>\n<footer class=\"ft\"><div class=\"wrap\"><div class=\"fcols\">\n    <div><div class=\"brand\"><span class=\"dot\"></span>The Long Game</div><p class=\"muted\" style=\"margin-top:.6rem;max-width:30ch\">Deep talks with the people quietly shaping the future, one idea at a time.</p></div>\n    <div><strong>Product</strong><a href=\"#\">Features</a><a href=\"#\">Pricing</a><a href=\"#\">Changelog</a></div><div><strong>Company</strong><a href=\"#\">About</a><a href=\"#\">Blog</a><a href=\"#\">Careers</a></div><div><strong>Legal</strong><a href=\"#\">Privacy</a><a href=\"#\">Terms</a><a href=\"#\">Status</a></div>\n  </div><p class=\"muted\" style=\"margin-top:1.8rem;font-size:.85rem\">© <span id=\"yr\"></span> The Long Game. All rights reserved.</p></div></footer>\n<footer class=\"ft\"><div class=\"wrap\"><div class=\"fcols\">\n    <div><div class=\"brand\"><span class=\"dot\"></span>The Long Game</div><p class=\"muted\" style=\"margin-top:.6rem;max-width:30ch\">Deep talks with the people quietly shaping the future, one idea at a time.</p></div>\n    <div><strong>Product</strong><a href=\"#\">Features</a><a href=\"#\">Pricing</a><a href=\"#\">Changelog</a></div><div><strong>Company</strong><a href=\"#\">About</a><a href=\"#\">Blog</a><a href=\"#\">Careers</a></div><div><strong>Legal</strong><a href=\"#\">Privacy</a><a href=\"#\">Terms</a><a href=\"#\">Status</a></div>\n  </div><p class=\"muted\" style=\"margin-top:1.8rem;font-size:.85rem\">© <span id=\"yr\"></span> The Long Game. All rights reserved.</p></div></footer>\n<script>\n(function(){\n  var bar=document.querySelector('.prog');\n  function sp(){if(!bar)return;var h=document.documentElement;var m=h.scrollHeight-h.clientHeight;bar.style.width=(m>0?(h.scrollTop/m*100):0)+'%';}\n  document.addEventListener('scroll',sp,{passive:true});sp();\n  var io=new IntersectionObserver(function(es){es.forEach(function(e){if(e.isIntersecting){e.target.classList.add('in');io.unobserve(e.target);}})},{threshold:.12});\n  document.querySelectorAll('.reveal').forEach(function(el){io.observe(el)});\n  var y=document.getElementById('yr');if(y)y.textContent=new Date().getFullYear();\n})();\n</script>\n</body>\n</html>\n"
}
