  "ai_usage": "Use for upload/download progress, scores, and timers. circumference = 2*pi*r; set the circle's stroke-dasharray to that, and stroke-dashoffset = circumference * (1 - pct). Rotate the circle -90deg so it starts at top. Update offset + the text label + aria-valuenow from JS as progress changes. The demo animates 0→100% on a loop.",
  "path": "effects/loaders-spinners/progress-ring.html",
  "source": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>Circular Progress Ring</title>\n  <script type=\"application/json\" id=\"effect-meta\">\n  {\n    \"id\": \"progress-ring\",\n    \"title\": \"Circular Progress Ring\",\n    \"summary\": \"A determinate SVG ring that fills to a percentage via stroke-dashoffset, with a live label.\",\n    \"description\": \"An SVG circle whose stroke-dasharray equals its circumference; animating stroke-dashoffset reveals the arc proportional to a percentage — the standard circular progress meter.\",\n    \"theme\": \"loaders-spinners\",\n    \"categories\": [\"loader\", \"progress\"],\n    \"tags\": [\"progress\", \"ring\", \"circular\", \"svg\", \"stroke-dashoffset\", \"percentage\"],\n    \"tech\": [\"css\", \"svg\", \"js\"],\n    \"era\": \"2020s\",\n    \"difficulty\": \"intermediate\",\n    \"dependencies\": [],\n    \"browser_support\": \"All modern browsers (SVG).\",\n    \"performance_notes\": \"Animating stroke-dashoffset is cheap. For pure decoration use CSS; for real values update from JS.\",\n    \"accessibility_notes\": \"Add role=progressbar with aria-valuenow/min/max and keep the numeric label as text so the value is announced. Not just color — the number conveys the state.\",\n    \"customization\": [\n      { \"name\": \"--track / --fill\", \"description\": \"Ring colors\", \"default\": \"#262c3d / #7c5cff\" },\n      { \"name\": \"r\", \"description\": \"Circle radius (drives circumference)\", \"default\": \"52\" }\n    ],\n    \"variations\": [\"Gradient stroke\", \"Rounded line caps\", \"Countdown timer ring\"],\n    \"related\": [\"ring-spinner\", \"progress-bar-indeterminate\"],\n    \"ai_usage\": \"Use for upload/download progress, scores, and timers. circumference = 2*pi*r; set the circle's stroke-dasharray to that, and stroke-dashoffset = circumference * (1 - pct). Rotate the circle -90deg so it starts at top. Update offset + the text label + aria-valuenow from JS as progress changes. The demo animates 0→100% on a loop.\"\n  }\n  </script>\n  <style>\n    :root { --track: #262c3d; --fill: #7c5cff; }\n    html, body { height: 100%; margin: 0; }\n    body { display: grid; place-items: center; background: #0b0d12; font-family: system-ui, sans-serif; }\n    .ring-wrap { position: relative; width: 130px; height: 130px; }\n    svg { transform: rotate(-90deg); }\n    .track { fill: none; stroke: var(--track); stroke-width: 12; }\n    .fill { fill: none; stroke: var(--fill); stroke-width: 12; stroke-linecap: round; transition: stroke-dashoffset .3s ease; }\n    .pct { position: absolute; inset: 0; display: grid; place-items: center; color: #e7ebf3; font-size: 1.6rem; font-weight: 800; }\n  </style>\n</head>\n<body>\n  <div class=\"ring-wrap\" role=\"progressbar\" aria-valuemin=\"0\" aria-valuemax=\"100\" aria-valuenow=\"0\" id=\"pb\">\n    <svg width=\"130\" height=\"130\" viewBox=\"0 0 130 130\">\n      <circle class=\"track\" cx=\"65\" cy=\"65\" r=\"52\"></circle>\n      <circle class=\"fill\" cx=\"65\" cy=\"65\" r=\"52\" id=\"fill\"></circle>\n    </svg>\n    <div class=\"pct\" id=\"label\">0%</div>\n  </div>\n  <script>\n    var r = 52, C = 2 * Math.PI * r;\n    var fill = document.getElementById(\"fill\"), label = document.getElementById(\"label\"), pb = document.getElementById(\"pb\");\n    fill.style.strokeDasharray = C;\n    function set(pct) {\n      fill.style.strokeDashoffset = C * (1 - pct / 100);\n      label.textContent = Math.round(pct) + \"%\";\n      pb.setAttribute(\"aria-valuenow\", String(Math.round(pct)));\n    }\n    set(0);\n    var p = 0;\n    setInterval(function () { p = (p + 1) % 101; set(p); }, 40);\n  </script>\n</body>\n</html>\n"
}
