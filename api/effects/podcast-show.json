  "ai_usage": "Use for podcasts and audio shows. Hero = cover art + title + play; add a subscribe row (Apple/Spotify/RSS), an episode list (number, title, date, duration, play button), and a host bio. Make play buttons real <button>s with aria-pressed and episode-naming labels; wire them to a real <audio> element. Keep the list semantic and disable the equalizer under reduced motion.",
  "path": "effects/website-templates/podcast-show.html",
  "source": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Podcast Show</title>\n<script type=\"application/json\" id=\"effect-meta\">\n{\n  \"id\": \"podcast-show\",\n  \"title\": \"Podcast Show\",\n  \"summary\": \"A podcast home: cover-art hero with a play button, subscribe-on-platform row, an episode list with durations, and a host bio.\",\n  \"description\": \"Everything a show needs on one page — a hero pairing cover art with title and a (mock) play control, buttons to subscribe across platforms, a clean episode list with numbers, durations, and play buttons that toggle a 'now playing' state, and an about-the-host section.\",\n  \"theme\": \"website-templates\",\n  \"categories\": [\"template\", \"creator\", \"media\"],\n  \"tags\": [\"podcast\", \"audio\", \"episodes\", \"creator\", \"media\", \"full-page\"],\n  \"tech\": [\"html\", \"css\", \"js\"],\n  \"era\": \"2020s\",\n  \"difficulty\": \"intermediate\",\n  \"dependencies\": [],\n  \"browser_support\": \"All modern browsers.\",\n  \"performance_notes\": \"A play-state toggle with an animated equalizer + reveals. No real audio/library (wire your <audio>).\",\n  \"accessibility_notes\": \"Play buttons are real buttons with aria-pressed and labels that name the episode; the episode list is semantic; focus-visible throughout. Equalizer stops under reduced-motion.\",\n  \"customization\": [\n    { \"name\": \"--accent\", \"description\": \"Brand accent\", \"default\": \"#ff6b4a\" },\n    { \"name\": \"episodes\", \"description\": \"List items (title, len, date)\", \"default\": \"edit markup\" }\n  ],\n  \"variations\": [\"Attach a real sticky <audio> player\", \"Seasons as tabs\", \"Transcript drawer per episode\"],\n  \"related\": [\"link-in-bio\", \"skeuomorphic-revival\", \"magazine-home\"],\n  \"ai_usage\": \"Use for podcasts and audio shows. Hero = cover art + title + play; add a subscribe row (Apple/Spotify/RSS), an episode list (number, title, date, duration, play button), and a host bio. Make play buttons real <button>s with aria-pressed and episode-naming labels; wire them to a real <audio> element. Keep the list semantic and disable the equalizer under reduced motion.\"\n}\n</script>\n<style>\n  :root{--bg:#0e0b14;--surface:#181320;--line:#2a2336;--text:#f0ecf6;--muted:#a79fb8;--accent:#ff6b4a;--accent2:#ffb454;--r:16px;}\n  *{box-sizing:border-box}html{scroll-behavior:smooth}\n  body{margin:0;background:var(--bg);color:var(--text);font-family:\"Inter\",system-ui,sans-serif;line-height:1.6}\n  a{color:inherit;text-decoration:none}\n  .wrap{max-width:980px;margin:0 auto;padding:0 1.4rem}\n  nav{display:flex;align-items:center;justify-content:space-between;height:66px}\n  .brand{font-weight:800}.links{display:flex;gap:1.3rem;color:var(--muted);font-size:.92rem}.links a:hover{color:var(--text)}\n  .hero{display:grid;grid-template-columns:260px 1fr;gap:2.2rem;align-items:center;padding:2rem 0 3rem}\n  .cover{aspect-ratio:1;border-radius:24px;background:linear-gradient(140deg,var(--accent),#b5179e);position:relative;box-shadow:0 30px 70px rgba(0,0,0,.5);display:grid;place-items:center}\n  .cover .mic{font-size:4rem}\n  .hero .ey{color:var(--accent2);font-weight:700;letter-spacing:.14em;text-transform:uppercase;font-size:.76rem}\n  .hero h1{font-size:clamp(2rem,5vw,3.2rem);font-weight:800;letter-spacing:-.02em;margin:.5rem 0}\n  .hero p{color:var(--muted);max-width:46ch}\n  .play-row{display:flex;align-items:center;gap:1rem;margin-top:1.2rem;flex-wrap:wrap}\n  .play{display:inline-flex;align-items:center;gap:.6rem;background:var(--accent);color:#fff;border:none;border-radius:999px;padding:.8rem 1.6rem;font-weight:800;cursor:pointer}\n  .subs{display:flex;gap:.6rem;flex-wrap:wrap}\n  .sub{background:var(--surface);border:1px solid var(--line);border-radius:999px;padding:.55rem 1rem;color:var(--muted);font-size:.85rem;font-weight:600}\n  .sub:hover{color:var(--text)}\n  .play:focus-visible,.sub:focus-visible,.ep .pb:focus-visible{outline:3px solid var(--accent2);outline-offset:3px}\n  section{padding:2.5rem 0}\n  h2{font-size:1.6rem;font-weight:800;margin:0 0 1.2rem}\n  .ep{display:grid;grid-template-columns:auto 1fr auto;gap:1rem;align-items:center;padding:1rem 0;border-top:1px solid var(--line)}\n  .ep .pb{width:46px;height:46px;border-radius:50%;border:1px solid var(--line);background:var(--surface);color:var(--text);cursor:pointer;font-size:1rem;display:grid;place-items:center}\n  .ep.playing .pb{background:var(--accent);border-color:transparent;color:#fff}\n  .ep h3{margin:0;font-size:1.05rem}.ep .meta{color:var(--muted);font-size:.85rem}\n  .ep .right{display:flex;align-items:center;gap:.8rem;color:var(--muted);font-size:.88rem}\n  .eq{display:none;align-items:flex-end;gap:2px;height:16px}.ep.playing .eq{display:flex}\n  .eq i{width:3px;background:var(--accent);border-radius:2px;height:40%;animation:eq .7s ease-in-out infinite alternate}\n  .eq i:nth-child(2){animation-delay:.15s}.eq i:nth-child(3){animation-delay:.3s}.eq i:nth-child(4){animation-delay:.1s}\n  @keyframes eq{to{height:100%}}\n  .host{display:grid;grid-template-columns:auto 1fr;gap:1.4rem;align-items:center;background:var(--surface);border:1px solid var(--line);border-radius:var(--r);padding:1.6rem}\n  .host .av{width:80px;height:80px;border-radius:50%;background:linear-gradient(135deg,var(--accent2),var(--accent))}\n  footer{border-top:1px solid var(--line);color:var(--muted);text-align:center;padding:2.2rem 0;font-size:.9rem}\n  .reveal{opacity:0;transform:translateY(20px);transition:opacity .6s,transform .6s ease}.reveal.in{opacity:1;transform:none}\n  @media(max-width:720px){.hero{grid-template-columns:1fr;text-align:center}.cover{max-width:240px;margin:0 auto}.hero p{margin-inline:auto}.play-row{justify-content:center}.host{grid-template-columns:1fr;text-align:center}.host .av{margin:0 auto}.links{display:none}}\n  @media(prefers-reduced-motion:reduce){.eq i{animation:none;height:70%}.reveal{opacity:1;transform:none;transition:none}html{scroll-behavior:auto}}\n</style>\n</head>\n<body>\n  <div class=\"wrap\">\n    <nav><div class=\"brand\">🎙️ The Long Game</div><div class=\"links\"><a href=\"#\">Episodes</a><a href=\"#\">About</a><a href=\"#\">Guests</a></div></nav>\n\n    <header class=\"hero\">\n      <div class=\"cover\" role=\"img\" aria-label=\"Podcast cover art\"><span class=\"mic\">🎙️</span></div>\n      <div>\n        <p class=\"ey\">Season 4 · New episodes Tuesdays</p>\n        <h1>The Long Game</h1>\n        <p>Deep, unhurried conversations with the people quietly shaping what comes next — one big idea at a time.</p>\n        <div class=\"play-row\">\n          <button class=\"play\" id=\"heroPlay\" aria-pressed=\"false\">▶ Play latest</button>\n          <div class=\"subs\"><span class=\"sub\">🎧 Apple</span><span class=\"sub\">🟢 Spotify</span><span class=\"sub\">📡 RSS</span></div>\n        </div>\n      </div>\n    </header>\n\n    <section>\n      <h2>Latest episodes</h2>\n      <div id=\"eps\">\n        <article class=\"ep\">\n          <button class=\"pb\" aria-pressed=\"false\" aria-label=\"Play episode 42: The patience premium\">▶</button>\n          <div><h3>42 · The patience premium</h3><div class=\"meta\">May 27, 2026 · with Dr. Aria Lund</div></div>\n          <div class=\"right\"><div class=\"eq\" aria-hidden=\"true\"><i></i><i></i><i></i><i></i></div><span>58 min</span></div>\n        </article>\n        <article class=\"ep\">\n          <button class=\"pb\" aria-pressed=\"false\" aria-label=\"Play episode 41: Building in silence\">▶</button>\n          <div><h3>41 · Building in silence</h3><div class=\"meta\">May 20, 2026 · with Kojo Mensah</div></div>\n          <div class=\"right\"><div class=\"eq\" aria-hidden=\"true\"><i></i><i></i><i></i><i></i></div><span>1 hr 04 min</span></div>\n        </article>\n        <article class=\"ep\">\n          <button class=\"pb\" aria-pressed=\"false\" aria-label=\"Play episode 40: The myth of the overnight\">▶</button>\n          <div><h3>40 · The myth of the overnight</h3><div class=\"meta\">May 13, 2026 · with Sofia Reyes</div></div>\n          <div class=\"right\"><div class=\"eq\" aria-hidden=\"true\"><i></i><i></i><i></i><i></i></div><span>49 min</span></div>\n        </article>\n      </div>\n    </section>\n\n    <section>\n      <div class=\"host reveal\">\n        <div class=\"av\" role=\"img\" aria-label=\"Host portrait\"></div>\n        <div><h2 style=\"font-size:1.3rem;margin:0 0 .3rem\">Hosted by Jordan Lee</h2><p style=\"color:var(--muted);margin:0\">Writer and recovering optimizer. Jordan started The Long Game to push back on hustle culture — one slow, careful conversation at a time.</p></div>\n      </div>\n    </section>\n\n    <footer>© <span id=\"yr\"></span> The Long Game · Listen wherever you get your podcasts.</footer>\n  </div>\n  <script>\n    document.getElementById('yr').textContent=new Date().getFullYear();\n    function toggle(btn,ep){\n      var on=btn.getAttribute('aria-pressed')!=='true';\n      // stop others\n      document.querySelectorAll('.ep').forEach(function(e){e.classList.remove('playing');var b=e.querySelector('.pb');if(b){b.setAttribute('aria-pressed','false');b.textContent='▶';}});\n      if(on){btn.setAttribute('aria-pressed','true');btn.textContent='⏸';if(ep)ep.classList.add('playing');}\n    }\n    document.querySelectorAll('.ep .pb').forEach(function(b){b.addEventListener('click',function(){toggle(b,b.closest('.ep'));});});\n    var hp=document.getElementById('heroPlay');\n    hp.addEventListener('click',function(){var on=hp.getAttribute('aria-pressed')!=='true';hp.setAttribute('aria-pressed',on);hp.textContent=on?'⏸ Playing latest':'▶ Play latest';});\n    var io=new IntersectionObserver(function(es){es.forEach(function(e){if(e.isIntersecting){e.target.classList.add('in');io.unobserve(e.target)}})},{threshold:.12});\n    document.querySelectorAll('.reveal').forEach(function(el){io.observe(el)});\n  </script>\n</body>\n</html>\n"
}
