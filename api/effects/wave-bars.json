  "ai_usage": "Use as a loading indicator or a music 'now playing' badge. Render N bars; animate transform: scaleY with one keyframe and stagger each bar's animation-delay so a wave travels across. For loading, wrap in role='status' with a hidden label; for decoration, aria-hide. Freeze to a static row under prefers-reduced-motion.",
  "path": "effects/loaders-spinners/wave-bars.html",
  "source": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>Wave Bars Loader</title>\n  <script type=\"application/json\" id=\"effect-meta\">\n  {\n    \"id\": \"wave-bars\",\n    \"title\": \"Wave Bars Loader\",\n    \"summary\": \"A row of bars that rise and fall in a travelling wave — an audio-equalizer-style loading / 'now playing' indicator.\",\n    \"description\": \"Several bars scale on the Y axis with staggered delays so a wave ripples across them. Doubles as a music 'now playing' indicator and a lightweight loading state.\",\n    \"theme\": \"loaders-spinners\",\n    \"categories\": [\"loader\", \"audio\", \"animation\"],\n    \"tags\": [\"equalizer\", \"bars\", \"wave\", \"audio\", \"loader\", \"now-playing\"],\n    \"tech\": [\"css\"],\n    \"era\": \"2020s\",\n    \"difficulty\": \"beginner\",\n    \"dependencies\": [],\n    \"browser_support\": \"All modern browsers.\",\n    \"performance_notes\": \"One keyframe reused with per-bar animation-delay; transform: scaleY only — GPU-friendly. Pure CSS.\",\n    \"accessibility_notes\": \"As a loader, wrap with role='status' + a visually-hidden 'Loading…' label; as a decorative 'now playing' indicator, mark aria-hidden. Stops to a static row under prefers-reduced-motion.\",\n    \"customization\": [\n      { \"name\": \"--c\", \"description\": \"Bar color/gradient\", \"default\": \"violet→teal\" },\n      { \"name\": \"count / --speed\", \"description\": \"Number of bars and cycle time\", \"default\": \"5 / 1s\" }\n    ],\n    \"variations\": [\"Mirror vertically for a symmetric EQ\", \"Color bars by index\", \"Randomize delays for organic motion\"],\n    \"related\": [\"dots-bounce\", \"orbit-loader\", \"podcast-show\"],\n    \"ai_usage\": \"Use as a loading indicator or a music 'now playing' badge. Render N bars; animate transform: scaleY with one keyframe and stagger each bar's animation-delay so a wave travels across. For loading, wrap in role='status' with a hidden label; for decoration, aria-hide. Freeze to a static row under prefers-reduced-motion.\"\n  }\n  </script>\n  <style>\n    :root{--speed:1s;}\n    html,body{height:100%;margin:0}\n    body{display:grid;place-items:center;background:#0b0d12}\n    .eq{display:flex;align-items:center;gap:7px;height:70px}\n    .eq span{width:9px;height:100%;border-radius:6px;background:linear-gradient(180deg,#7c5cff,#2dd4bf);transform:scaleY(.2);transform-origin:center;\n      animation:wave var(--speed) ease-in-out infinite}\n    .eq span:nth-child(1){animation-delay:0s}.eq span:nth-child(2){animation-delay:.12s}.eq span:nth-child(3){animation-delay:.24s}\n    .eq span:nth-child(4){animation-delay:.36s}.eq span:nth-child(5){animation-delay:.48s}.eq span:nth-child(6){animation-delay:.6s}.eq span:nth-child(7){animation-delay:.72s}\n    @keyframes wave{0%,100%{transform:scaleY(.2)}50%{transform:scaleY(1)}}\n    .sr{position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0 0 0 0)}\n    @media(prefers-reduced-motion:reduce){.eq span{animation:none;transform:scaleY(.6)}}\n  </style>\n</head>\n<body>\n  <div role=\"status\">\n    <div class=\"eq\" aria-hidden=\"true\"><span></span><span></span><span></span><span></span><span></span><span></span><span></span></div>\n    <span class=\"sr\">Loading…</span>\n  </div>\n</body>\n</html>\n"
}
