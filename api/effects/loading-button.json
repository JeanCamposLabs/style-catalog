{
  "id": "loading-button",
  "title": "Loading Button",
  "summary": "A submit button that swaps its label for an inline spinner and locks during async work.",
  "description": "Toggling a loading state hides the label, shows a spinner, disables the button, and sets aria-busy — the correct pattern for form submits and async actions.",
