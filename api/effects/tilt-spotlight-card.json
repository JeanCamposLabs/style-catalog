  "ai_usage": "Use for feature/pricing/product cards on premium landings. Set perspective on the parent; on pointermove map the cursor's position within the card to rotateX/rotateY (invert Y) and to a --mx/--my used by a radial-gradient spotlight overlay; reset on leave. Keep content above the spotlight layer, preserve focus order, and disable under reduced motion.",
  "path": "effects/hover-interactions/tilt-spotlight-card.html",
  "source": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>Tilt + Spotlight Card</title>\n  <script type=\"application/json\" id=\"effect-meta\">\n  {\n    \"id\": \"tilt-spotlight-card\",\n    \"title\": \"Tilt + Spotlight Card\",\n    \"summary\": \"A card that tilts in 3D toward the cursor while a soft spotlight follows the pointer across its surface.\",\n    \"description\": \"Two effects in one interaction: the card rotates on X/Y based on pointer position (parallax depth), and a radial 'spotlight' highlight tracks the cursor via CSS custom properties. The signature hover for premium feature/pricing cards.\",\n    \"theme\": \"hover-interactions\",\n    \"categories\": [\"hover\", \"3d\", \"card\"],\n    \"tags\": [\"tilt\", \"3d\", \"spotlight\", \"parallax\", \"cursor\", \"card\", \"2026-trend\"],\n    \"tech\": [\"css\", \"js\"],\n    \"era\": \"2020s\",\n    \"difficulty\": \"intermediate\",\n    \"dependencies\": [],\n    \"browser_support\": \"All modern browsers (CSS 3D transforms, custom properties).\",\n    \"performance_notes\": \"One pointermove updates two CSS vars (rotation) + spotlight position. transform/opacity only — GPU-friendly.\",\n    \"accessibility_notes\": \"Decorative; content stays readable and focusable. Effect is pointer-only and disabled under prefers-reduced-motion.\",\n    \"customization\": [\n      { \"name\": \"--max-tilt\", \"description\": \"Max rotation degrees\", \"default\": \"10deg\" },\n      { \"name\": \"spotlight color/size\", \"description\": \"Radial highlight\", \"default\": \"white 20% / 240px\" }\n    ],\n    \"variations\": [\"Spotlight only (no tilt)\", \"Add a glare streak\", \"Stronger tilt for hero product shots\"],\n    \"related\": [\"card-lift\", \"magnetic-button\", \"layered-depth-hover\"],\n    \"ai_usage\": \"Use for feature/pricing/product cards on premium landings. Set perspective on the parent; on pointermove map the cursor's position within the card to rotateX/rotateY (invert Y) and to a --mx/--my used by a radial-gradient spotlight overlay; reset on leave. Keep content above the spotlight layer, preserve focus order, and disable under reduced motion.\"\n  }\n  </script>\n  <style>\n    :root{--max-tilt:10;}\n    html,body{height:100%;margin:0}\n    body{display:grid;place-items:center;background:#0b0d12;font-family:system-ui,sans-serif;perspective:900px}\n    .card{position:relative;width:300px;border-radius:20px;background:#12151f;border:1px solid #242a3b;color:#e8ecf6;\n      padding:1.8rem;transform-style:preserve-3d;transition:transform .3s ease;overflow:hidden;--mx:50%;--my:50%}\n    .card::before{content:\"\";position:absolute;inset:0;background:radial-gradient(240px circle at var(--mx) var(--my),rgba(124,92,255,.28),transparent 60%);\n      opacity:0;transition:opacity .3s;pointer-events:none}\n    .card:hover::before{opacity:1}\n    .card .ic{font-size:1.8rem}.card h3{margin:.6rem 0 .3rem}.card p{color:#8b93a7;margin:0;font-size:.95rem}\n    @media(prefers-reduced-motion:reduce){.card{transition:none}.card::before{display:none}}\n  </style>\n</head>\n<body>\n  <article class=\"card\" id=\"card\">\n    <div class=\"ic\">✦</div>\n    <h3>Realtime sync</h3>\n    <p>Move your cursor across the card — it tilts in 3D and a spotlight follows.</p>\n  </article>\n  <script>\n    var card=document.getElementById('card');\n    var max=parseFloat(getComputedStyle(document.documentElement).getPropertyValue('--max-tilt'))||10;\n    var reduce=matchMedia('(prefers-reduced-motion: reduce)').matches;\n    if(!reduce){\n      card.addEventListener('pointermove',function(e){\n        var r=card.getBoundingClientRect();\n        var px=(e.clientX-r.left)/r.width, py=(e.clientY-r.top)/r.height;\n        card.style.transform='rotateY('+((px-.5)*2*max)+'deg) rotateX('+((.5-py)*2*max)+'deg)';\n        card.style.setProperty('--mx',(px*100)+'%');\n        card.style.setProperty('--my',(py*100)+'%');\n      });\n      card.addEventListener('pointerleave',function(){card.style.transform='';});\n    }\n  </script>\n</body>\n</html>\n"
}
