{
  "id": "stagger-choreography",
  "title": "Stagger Choreography",
  "summary": "A list whose items animate in one after another with an incremental delay.",
  "description": "Demonstrates staggering: the same entrance animation applied to siblings with animation-delay derived from each item's index, so they cascade rather than appear at once — a core motion-design principle.",
