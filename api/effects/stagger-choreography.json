  ],
  "era": "timeless",
  "difficulty": "beginner",
  "dependencies": [],
  "browser_support": "All browsers.",
  "performance_notes": "Transform/opacity per item; cheap. The delay is set via an --i custom property * a step.",
  "accessibility_notes": "Keep the total stagger short so content isn't withheld too long. Disable (show all at once) under prefers-reduced-motion.",
  "customization": [
    {
      "name": "--step",
