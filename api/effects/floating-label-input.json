  "id": "floating-label-input",
  "title": "Floating Label Input",
  "summary": "A label that sits inside the field and floats up when focused or filled — pure CSS, fully accessible.",
  "description": "Uses an empty placeholder plus :placeholder-shown and :focus to animate a real <label> from inside the input to above it, keeping the label available to assistive tech.",
