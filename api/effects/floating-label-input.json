  "difficulty": "beginner",
  "dependencies": [],
  "browser_support": "All modern browsers (:placeholder-shown).",
  "performance_notes": "Static + a transform transition; trivial.",
  "accessibility_notes": "Critically: keep a REAL <label for> — do not use a placeholder as the only label. The input needs placeholder=' ' (a space) so :placeholder-shown works. Focus styles are visible.",
