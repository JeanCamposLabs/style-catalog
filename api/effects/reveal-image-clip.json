  "ai_usage": "Use for figure/image reveals in articles and case studies. Start the image clipped (clip-path: inset(0 100% 0 0)) and transition to inset(0) when an IntersectionObserver adds the .in class. Change which inset side is 100% to set wipe direction. Short-circuit to fully revealed under prefers-reduced-motion. The demo auto-scrolls so the wipe is visible in the catalog frame.",
  "path": "effects/scroll-effects/reveal-image-clip.html",
  "source": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>Image Clip Reveal on Scroll</title>\n  <script type=\"application/json\" id=\"effect-meta\">\n  {\n    \"id\": \"reveal-image-clip\",\n    \"title\": \"Image Clip Reveal on Scroll\",\n    \"summary\": \"An image unveils behind a clip-path wipe as it scrolls into view.\",\n    \"description\": \"Combines IntersectionObserver with a clip-path inset transition so the image is wiped into view (rather than just faded) when it enters the viewport — a premium editorial reveal.\",\n    \"theme\": \"scroll-effects\",\n    \"categories\": [\"scroll\", \"reveal\", \"image\"],\n    \"tags\": [\"reveal\", \"clip-path\", \"scroll\", \"wipe\", \"intersection-observer\", \"image\"],\n    \"tech\": [\"css\", \"js\"],\n    \"era\": \"2020s\",\n    \"difficulty\": \"intermediate\",\n    \"dependencies\": [],\n    \"browser_support\": \"All modern browsers.\",\n    \"performance_notes\": \"Animating clip-path is GPU-friendly; the observer fires once per element.\",\n    \"accessibility_notes\": \"Image is in the DOM regardless; under prefers-reduced-motion show it immediately (no clip). Provide real alt text.\",\n    \"customization\": [\n      { \"name\": \"--ease / duration\", \"description\": \"Wipe timing\", \"default\": \"0.9s cubic-bezier(.22,1,.36,1)\" },\n      { \"name\": \"direction\", \"description\": \"inset side that opens\", \"default\": \"left-to-right\" }\n    ],\n    \"variations\": [\"Reveal direction per item (alternating)\", \"Combine with a slight scale for depth\", \"Circle/iris reveal via circle() clip-path\"],\n    \"related\": [\"scroll-reveal-fade\", \"clip-path-shapes\", \"text-reveal-mask\"],\n    \"ai_usage\": \"Use for figure/image reveals in articles and case studies. Start the image clipped (clip-path: inset(0 100% 0 0)) and transition to inset(0) when an IntersectionObserver adds the .in class. Change which inset side is 100% to set wipe direction. Short-circuit to fully revealed under prefers-reduced-motion. The demo auto-scrolls so the wipe is visible in the catalog frame.\"\n  }\n  </script>\n  <style>\n    * { box-sizing: border-box; }\n    html, body { margin: 0; }\n    body { background: #0b0d12; font-family: system-ui, sans-serif; }\n    .scroller { height: 100vh; overflow-y: auto; padding: 1rem; }\n    .spacer { height: 60vh; }\n    .figure { width: 280px; height: 180px; margin: 1rem auto; border-radius: 14px; overflow: hidden; }\n    .figure .img {\n      width: 100%; height: 100%; background: linear-gradient(135deg,#7c5cff,#2dd4bf);\n      clip-path: inset(0 100% 0 0); transition: clip-path .9s cubic-bezier(.22,1,.36,1);\n    }\n    .figure.in .img { clip-path: inset(0 0 0 0); }\n    @media (prefers-reduced-motion: reduce) { .figure .img { transition: none; clip-path: inset(0); } }\n  </style>\n</head>\n<body>\n  <div class=\"scroller\" id=\"scroller\">\n    <div class=\"spacer\"></div>\n    <div class=\"figure\"><div class=\"img\"></div></div>\n    <div class=\"figure\"><div class=\"img\"></div></div>\n    <div class=\"figure\"><div class=\"img\"></div></div>\n    <div class=\"spacer\"></div>\n  </div>\n  <script>\n    var root = document.getElementById(\"scroller\");\n    var io = new IntersectionObserver(function (es) {\n      es.forEach(function (e) { if (e.isIntersecting) { e.target.classList.add(\"in\"); io.unobserve(e.target); } });\n    }, { root: root, threshold: 0.4 });\n    document.querySelectorAll(\".figure\").forEach(function (f) { io.observe(f); });\n    if (!matchMedia(\"(prefers-reduced-motion: reduce)\").matches) {\n      var dir = 1;\n      setInterval(function () {\n        root.scrollTop += dir * 2;\n        if (root.scrollTop + root.clientHeight >= root.scrollHeight - 2) dir = -1;\n        if (root.scrollTop <= 0) dir = 1;\n      }, 16);\n    }\n  </script>\n</body>\n</html>\n"
}
