  "ai_usage": "Standard nav/link hover. Link is position:relative; a ::after is an absolutely-positioned 2px bar at the bottom, scaleX(0) with transform-origin:center, transitioning to scaleX(1) on hover AND focus-visible. Change transform-origin to left for a directional slide. Always include :focus-visible for keyboard accessibility.",
  "path": "effects/navigation-menus/underline-grow-link.html",
  "source": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>Animated Underline Links</title>\n  <script type=\"application/json\" id=\"effect-meta\">\n  {\n    \"id\": \"underline-grow-link\",\n    \"title\": \"Animated Underline Links\",\n    \"summary\": \"Nav links whose underline grows from the center (or slides in) on hover/focus.\",\n    \"description\": \"Uses a scaleX-animated pseudo-element underline with transform-origin so it grows from center, plus a left-to-right slide variant — the cleanest way to animate underlines.\",\n    \"theme\": \"navigation-menus\",\n    \"categories\": [\"navigation\", \"link\", \"hover\"],\n    \"tags\": [\"underline\", \"link\", \"hover\", \"nav\", \"scaleX\", \"focus\"],\n    \"tech\": [\"css\"],\n    \"era\": \"timeless\",\n    \"difficulty\": \"beginner\",\n    \"dependencies\": [],\n    \"browser_support\": \"All browsers.\",\n    \"performance_notes\": \"Transform-only on a pseudo-element — GPU-friendly.\",\n    \"accessibility_notes\": \"Apply the same effect on :focus-visible, not just :hover, so keyboard users see it. Keep an accessible color/contrast for the link text itself.\",\n    \"customization\": [\n      { \"name\": \"--line\", \"description\": \"Underline color\", \"default\": \"#7c5cff\" },\n      { \"name\": \"transform-origin\", \"description\": \"center | left for grow direction\", \"default\": \"center\" }\n    ],\n    \"variations\": [\"Slide-in from left\", \"Thicker highlight bar behind text\", \"Two-line draw on hover\"],\n    \"related\": [\"fill-sweep-button\"],\n    \"ai_usage\": \"Standard nav/link hover. Link is position:relative; a ::after is an absolutely-positioned 2px bar at the bottom, scaleX(0) with transform-origin:center, transitioning to scaleX(1) on hover AND focus-visible. Change transform-origin to left for a directional slide. Always include :focus-visible for keyboard accessibility.\"\n  }\n  </script>\n  <style>\n    :root { --line: #7c5cff; }\n    html, body { height: 100%; margin: 0; }\n    body { display: grid; place-items: center; background: #0b0d12; font-family: system-ui, sans-serif; }\n    nav { display: flex; gap: 2rem; }\n    .nav-link {\n      position: relative; color: #e7ebf3; text-decoration: none; font-size: 1.1rem; padding: .2rem 0;\n    }\n    .nav-link::after {\n      content: \"\"; position: absolute; left: 0; right: 0; bottom: 0; height: 2px; background: var(--line);\n      transform: scaleX(0); transform-origin: center; transition: transform .3s ease;\n    }\n    .nav-link:hover::after, .nav-link:focus-visible::after { transform: scaleX(1); }\n    .nav-link.slide::after { transform-origin: left; }\n    @media (prefers-reduced-motion: reduce) { .nav-link::after { transition: none; } }\n  </style>\n</head>\n<body>\n  <nav>\n    <a class=\"nav-link\" href=\"#\">Home</a>\n    <a class=\"nav-link\" href=\"#\">Work</a>\n    <a class=\"nav-link slide\" href=\"#\">About</a>\n    <a class=\"nav-link\" href=\"#\">Contact</a>\n  </nav>\n</body>\n</html>\n"
}
