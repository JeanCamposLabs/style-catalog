{
  "id": "typewriter-text",
  "title": "Typewriter Text",
  "summary": "Text types itself out with a blinking caret using the steps() timing function.",
  "description": "Animates max-width / width from 0 with steps() so characters appear one glyph at a time, plus a border-right caret that blinks.",
