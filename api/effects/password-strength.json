  "ai_usage": "Use on sign-up and password-change forms. On input, score the value against rules (length, lower/upper, number, symbol), set the bar width/color and a text label, and tick the checklist. Announce the label via aria-live='polite' so it isn't color-only, give the show/hide toggle aria-pressed, and keep the input properly labeled. Don't block paste from password managers.",
  "path": "effects/forms-inputs/password-strength.html",
  "source": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>Password Strength Meter</title>\n  <script type=\"application/json\" id=\"effect-meta\">\n  {\n    \"id\": \"password-strength\",\n    \"title\": \"Password Strength Meter\",\n    \"summary\": \"A password field with a live strength bar, a weak→strong label, a show/hide toggle, and a ticking requirements checklist.\",\n    \"description\": \"As the user types, a segmented bar fills and recolors (red→amber→green), a label updates, and a checklist of requirements (length, case, number, symbol) checks off — the standard, reassuring sign-up affordance.\",\n    \"theme\": \"forms-inputs\",\n    \"categories\": [\"form\", \"input\", \"validation\"],\n    \"tags\": [\"password\", \"strength\", \"meter\", \"validation\", \"checklist\", \"show-hide\"],\n    \"tech\": [\"css\", \"js\"],\n    \"era\": \"2020s\",\n    \"difficulty\": \"intermediate\",\n    \"dependencies\": [],\n    \"browser_support\": \"All modern browsers.\",\n    \"performance_notes\": \"A few regex tests on input; negligible.\",\n    \"accessibility_notes\": \"Strength is announced via aria-live (not color-only); the show/hide button has aria-pressed and toggles input type; the checklist items use text + aria-checked. Real labeled input.\",\n    \"customization\": [\n      { \"name\": \"rules\", \"description\": \"Requirement checks + weights\", \"default\": \"len/case/num/symbol\" },\n      { \"name\": \"colors\", \"description\": \"weak/medium/strong\", \"default\": \"red/amber/green\" }\n    ],\n    \"variations\": [\"zxcvbn-style scoring\", \"Inline 'breached password' warning\", \"Minimum-bar gate on submit\"],\n    \"related\": [\"floating-label-input\", \"otp-input\", \"animated-checkbox\"],\n    \"ai_usage\": \"Use on sign-up and password-change forms. On input, score the value against rules (length, lower/upper, number, symbol), set the bar width/color and a text label, and tick the checklist. Announce the label via aria-live='polite' so it isn't color-only, give the show/hide toggle aria-pressed, and keep the input properly labeled. Don't block paste from password managers.\"\n  }\n  </script>\n  <style>\n    :root{--weak:#ef4444;--mid:#f59e0b;--strong:#22c55e;--bg:#11131b;--line:#2a3040;--text:#e8ecf6;--muted:#8b93a7;}\n    html,body{height:100%;margin:0}\n    body{display:grid;place-items:center;background:#0b0d12;color:var(--text);font-family:system-ui,sans-serif}\n    .field{width:min(360px,90vw)}\n    label{display:block;font-weight:600;margin-bottom:.5rem}\n    .input{display:flex;align-items:center;background:var(--bg);border:1px solid var(--line);border-radius:12px;padding:.2rem .4rem .2rem .9rem}\n    .input input{flex:1;border:none;outline:none;background:transparent;color:var(--text);font-size:1rem;padding:.7rem 0}\n    .input button{background:none;border:none;color:var(--muted);cursor:pointer;font-size:.85rem;padding:.4rem .6rem}\n    .input:focus-within{border-color:#7c5cff;box-shadow:0 0 0 4px rgba(124,92,255,.2)}\n    .bars{display:flex;gap:6px;margin:.7rem 0 .4rem}\n    .bars i{height:6px;flex:1;border-radius:4px;background:var(--line);transition:background .25s}\n    .label{font-size:.85rem;font-weight:700;min-height:1.2em}\n    ul{list-style:none;padding:0;margin:.8rem 0 0;color:var(--muted);font-size:.85rem}\n    li{padding:.18rem 0;transition:color .2s}li::before{content:\"○ \";}\n    li.ok{color:var(--strong)}li.ok::before{content:\"✓ \"}\n  </style>\n</head>\n<body>\n  <div class=\"field\">\n    <label for=\"pw\">Create a password</label>\n    <div class=\"input\">\n      <input id=\"pw\" type=\"password\" autocomplete=\"new-password\" placeholder=\"••••••••\" />\n      <button id=\"toggle\" type=\"button\" aria-pressed=\"false\" aria-label=\"Show password\">Show</button>\n    </div>\n    <div class=\"bars\" aria-hidden=\"true\"><i></i><i></i><i></i><i></i></div>\n    <div class=\"label\" id=\"label\" role=\"status\" aria-live=\"polite\"></div>\n    <ul id=\"rules\">\n      <li data-k=\"len\">At least 8 characters</li>\n      <li data-k=\"case\">Upper &amp; lowercase letters</li>\n      <li data-k=\"num\">A number</li>\n      <li data-k=\"sym\">A symbol</li>\n    </ul>\n  </div>\n  <script>\n    var pw=document.getElementById('pw'),bars=document.querySelectorAll('.bars i'),label=document.getElementById('label'),toggle=document.getElementById('toggle');\n    var rules=[].slice.call(document.querySelectorAll('#rules li'));\n    var COLORS=['','var(--weak)','var(--mid)','var(--mid)','var(--strong)'];\n    var WORDS=['','Weak','Fair','Good','Strong'];\n    function score(v){\n      var checks={len:v.length>=8,case:/[a-z]/.test(v)&&/[A-Z]/.test(v),num:/\\d/.test(v),sym:/[^A-Za-z0-9]/.test(v)};\n      rules.forEach(function(li){li.classList.toggle('ok',checks[li.dataset.k]);});\n      return Object.keys(checks).reduce(function(n,k){return n+(checks[k]?1:0)},0);\n    }\n    pw.addEventListener('input',function(){\n      var s=pw.value?score(pw.value):0;\n      bars.forEach(function(b,i){b.style.background=i<s?COLORS[s]:'var(--line)';});\n      label.textContent=pw.value?WORDS[s]+' password':'';\n      label.style.color=COLORS[s]||'var(--muted)';\n    });\n    toggle.addEventListener('click',function(){\n      var show=pw.type==='password';pw.type=show?'text':'password';\n      toggle.textContent=show?'Hide':'Show';toggle.setAttribute('aria-pressed',show);toggle.setAttribute('aria-label',show?'Hide password':'Show password');\n    });\n  </script>\n</body>\n</html>\n"
}
