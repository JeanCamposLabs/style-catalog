  "ai_usage": "Drop-in sticky site header. The bar is position:sticky top:0 with a translucent background + backdrop-filter blur + 1px bottom border. Links use a scaleX underline pseudo-element (hover + focus-visible). Include a -webkit-backdrop-filter and a solid-background fallback. For mobile, pair with the hamburger-morph effect to toggle a menu. The demo scrolls content beneath so the blur is visible in the catalog frame.",
  "path": "effects/combos-recipes/glass-navbar.html",
  "source": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>Glass Navbar (composed)</title>\n  <script type=\"application/json\" id=\"effect-meta\">\n  {\n    \"id\": \"glass-navbar\",\n    \"title\": \"Glass Navbar (composed)\",\n    \"summary\": \"A sticky frosted-glass navigation bar with animated underline links and a gradient CTA.\",\n    \"description\": \"Composes glassmorphism + underline-grow links + a gradient button into a production-ready sticky header that blurs the content scrolling beneath it.\",\n    \"theme\": \"combos-recipes\",\n    \"categories\": [\"recipe\", \"navigation\", \"header\"],\n    \"tags\": [\"navbar\", \"glass\", \"sticky\", \"underline\", \"header\", \"composition\"],\n    \"tech\": [\"css\"],\n    \"era\": \"2020s\",\n    \"difficulty\": \"intermediate\",\n    \"dependencies\": [],\n    \"browser_support\": \"All modern browsers; backdrop-filter needs -webkit- in Safari.\",\n    \"performance_notes\": \"backdrop-filter on a thin bar is fine. Underline animates transform only.\",\n    \"accessibility_notes\": \"Semantic <nav>; links show the underline on :focus-visible too. Ensure link contrast over the blurred backdrop; provide a solid fallback where backdrop-filter is unsupported.\",\n    \"customization\": [\n      { \"name\": \"--glass\", \"description\": \"Bar tint/opacity\", \"default\": \"rgba(17,20,28,.6)\" },\n      { \"name\": \"--accent\", \"description\": \"Underline + CTA color\", \"default\": \"#7c5cff\" }\n    ],\n    \"variations\": [\"Add the hamburger-morph toggle for mobile\", \"Shrink-on-scroll height\", \"Light-mode glass tint\"],\n    \"related\": [\"glassmorphism-card\", \"underline-grow-link\", \"gradient-border-button\", \"hamburger-morph\"],\n    \"ai_usage\": \"Drop-in sticky site header. The bar is position:sticky top:0 with a translucent background + backdrop-filter blur + 1px bottom border. Links use a scaleX underline pseudo-element (hover + focus-visible). Include a -webkit-backdrop-filter and a solid-background fallback. For mobile, pair with the hamburger-morph effect to toggle a menu. The demo scrolls content beneath so the blur is visible in the catalog frame.\"\n  }\n  </script>\n  <style>\n    :root { --glass: rgba(17,20,28,.6); --accent: #7c5cff; }\n    * { box-sizing: border-box; }\n    html, body { margin: 0; }\n    body { font-family: system-ui, sans-serif; }\n    .page { height: 100vh; overflow-y: auto; background: linear-gradient(160deg, #1a1040, #2dd4bf22 60%, #0b0d12); }\n    .navbar {\n      position: sticky; top: 0; display: flex; align-items: center; justify-content: space-between;\n      padding: .9rem 1.4rem; background: var(--glass);\n      -webkit-backdrop-filter: blur(12px); backdrop-filter: blur(12px);\n      border-bottom: 1px solid rgba(255,255,255,.12); z-index: 10;\n    }\n    .brand { color: #fff; font-weight: 800; font-size: 1.15rem; }\n    .nav-links { display: flex; gap: 1.4rem; align-items: center; }\n    .nav-links a { position: relative; color: #e7ebf3; text-decoration: none; font-size: .95rem; padding: .2rem 0; }\n    .nav-links a::after { content: \"\"; position: absolute; left: 0; right: 0; bottom: -2px; height: 2px; background: var(--accent);\n      transform: scaleX(0); transform-origin: center; transition: transform .25s; }\n    .nav-links a:hover::after, .nav-links a:focus-visible::after { transform: scaleX(1); }\n    .nav-cta { color: #fff; background: var(--accent); border: none; border-radius: 10px; padding: .55rem 1.1rem; font-weight: 700; cursor: pointer; }\n    .filler { padding: 2rem 1.4rem; color: #e7ebf3; }\n    .filler div { height: 90px; margin: 1rem 0; border-radius: 12px; background: rgba(255,255,255,.08); }\n    @media (prefers-reduced-motion: reduce) { .nav-links a::after { transition: none; } }\n  </style>\n</head>\n<body>\n  <div class=\"page\" id=\"page\">\n    <nav class=\"navbar\">\n      <span class=\"brand\">◆ Lumen</span>\n      <div class=\"nav-links\">\n        <a href=\"#\">Product</a><a href=\"#\">Pricing</a><a href=\"#\">Docs</a>\n        <button class=\"nav-cta\">Sign up</button>\n      </div>\n    </nav>\n    <div class=\"filler\">\n      <h2>Scroll — the bar frosts the content beneath it.</h2>\n      <div></div><div></div><div></div><div></div><div></div>\n    </div>\n  </div>\n  <script>\n    if (!matchMedia(\"(prefers-reduced-motion: reduce)\").matches) {\n      var p = document.getElementById(\"page\"), dir = 1;\n      setInterval(function () {\n        p.scrollTop += dir * 2;\n        if (p.scrollTop + p.clientHeight >= p.scrollHeight - 2) dir = -1;\n        if (p.scrollTop <= 0) dir = 1;\n      }, 16);\n    }\n  </script>\n</body>\n</html>\n"
}
