  "path": "effects/website-templates/clay-app.html",
  "source": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Claymorphism — Friendly App</title>\n<script type=\"application/json\" id=\"effect-meta\">\n{\n  \"id\": \"clay-app\",\n  \"title\": \"Claymorphism — Friendly App\",\n  \"summary\": \"A warm consumer-app landing in the claymorphism trend: soft, puffy 3D shapes with inner + outer shadows, rounded everything, pastel palette.\",\n  \"description\": \"Claymorphism — soft, inflated 'clay' surfaces made with layered inset and drop shadows — reads friendly and tactile, ideal for consumer and kids' apps. This is a habit/wellness app landing: puffy cards, a clay phone mock, rounded feature pills, and a gentle pastel scheme.\",\n  \"theme\": \"website-templates\",\n  \"categories\": [\"template\", \"landing\", \"app\"],\n  \"tags\": [\"claymorphism\", \"soft-ui\", \"pastel\", \"app\", \"friendly\", \"3d\", \"2026-trend\", \"full-page\"],\n  \"tech\": [\"html\", \"css\", \"js\"],\n  \"era\": \"2020s\",\n  \"difficulty\": \"beginner\",\n  \"dependencies\": [],\n  \"browser_support\": \"All modern browsers.\",\n  \"performance_notes\": \"All effect is layered box-shadow (outer drop + two inset highlights). No images. Gentle bob animation on the mock.\",\n  \"accessibility_notes\": \"Soft palette keeps text dark for contrast; focus-visible; bob animation stops under reduced-motion.\",\n  \"customization\": [\n    { \"name\": \"--clay shadow recipe\", \"description\": \"Outer + inset highlight/shadow\", \"default\": \"soft\" },\n    { \"name\": \"--c1/--c2\", \"description\": \"Accent clays\", \"default\": \"lavender / mint\" }\n  ],\n  \"variations\": [\"Darker clay (mud) palette\", \"Single accent clay\", \"Real app screenshot inside the clay phone\"],\n  \"related\": [\"card-lift\"],\n  \"ai_usage\": \"Use for consumer, wellness, kids, or playful productivity apps. The clay effect is one box-shadow stack: an outer drop shadow plus inset light (top-left) and inset dark (bottom-right). Keep corners very round and the palette pastel. Recolor via --c1/--c2. Drop a real screenshot into the clay phone. Reduced-motion safe.\"\n}\n</script>\n<style>\n  :root{--bg:#eef0fb;--surface:#f6f7ff;--ink:#2b2a4a;--muted:#7a799c;--c1:#b8a6ff;--c2:#88e0c8;--c3:#ffc7e0;\n    --clay:8px 8px 20px rgba(120,120,170,.35),-8px -8px 20px rgba(255,255,255,.9),inset 2px 2px 4px rgba(255,255,255,.7),inset -3px -3px 6px rgba(120,120,170,.2);\n    --r:30px;}\n  *{box-sizing:border-box}html{scroll-behavior:smooth}\n  body{margin:0;background:var(--bg);color:var(--ink);font-family:\"Quicksand\",\"Nunito\",system-ui,sans-serif;font-weight:600;line-height:1.6}\n  a{color:inherit;text-decoration:none}\n  .wrap{max-width:1080px;margin:0 auto;padding:0 1.4rem}\n  nav{display:flex;align-items:center;justify-content:space-between;height:80px}\n  .brand{font-weight:800;font-size:1.3rem;display:flex;align-items:center;gap:.5rem}\n  .brand .blob{width:30px;height:30px;border-radius:12px;background:linear-gradient(145deg,var(--c1),var(--c3));box-shadow:var(--clay)}\n  .links{display:flex;gap:1.3rem;align-items:center;color:var(--muted)}.links a:hover{color:var(--ink)}\n  .btn{display:inline-block;background:linear-gradient(145deg,var(--c1),#9f86ff);color:#fff;font-weight:800;border:none;border-radius:999px;padding:.7rem 1.4rem;cursor:pointer;\n    box-shadow:6px 6px 16px rgba(120,100,200,.4),-4px -4px 12px rgba(255,255,255,.8),inset 2px 2px 4px rgba(255,255,255,.4);transition:transform .15s}\n  .btn:hover{transform:translateY(-3px)}.btn:active{transform:translateY(1px)}\n  .btn.mint{background:linear-gradient(145deg,var(--c2),#5fd1b4);color:#0c3b30}\n  .btn:focus-visible{outline:3px solid var(--c1);outline-offset:3px}\n  .hero{display:grid;grid-template-columns:1.05fr .95fr;gap:2.5rem;align-items:center;padding:3rem 0 4rem}\n  .pill{display:inline-block;background:var(--surface);border-radius:999px;padding:.5rem 1rem;box-shadow:var(--clay);font-size:.85rem;color:var(--muted)}\n  h1{font-size:clamp(2.4rem,6vw,4rem);font-weight:800;line-height:1.05;letter-spacing:-.02em;margin:1.1rem 0 .7rem}\n  h1 .g{background:linear-gradient(120deg,var(--c1),var(--c2));-webkit-background-clip:text;background-clip:text;color:transparent}\n  .sub{color:var(--muted);font-size:1.15rem;max-width:40ch;margin:0 0 1.6rem}\n  .ctas{display:flex;gap:.8rem;flex-wrap:wrap}\n  .phone{justify-self:center;width:260px;height:520px;border-radius:48px;background:var(--surface);box-shadow:var(--clay);padding:18px;animation:bob 5s ease-in-out infinite}\n  @keyframes bob{50%{transform:translateY(-16px)}}\n  .screen{height:100%;border-radius:34px;background:linear-gradient(160deg,#fdfdff,#eef0fb);padding:1.2rem;display:flex;flex-direction:column;gap:.9rem;box-shadow:inset 4px 4px 10px rgba(120,120,170,.2)}\n  .screen .top{font-weight:800}.screen .ring{width:90px;height:90px;border-radius:50%;margin:.3rem auto;background:conic-gradient(var(--c2) 75%, #dfe2f5 0);display:grid;place-items:center;box-shadow:var(--clay)}\n  .screen .ring b{background:var(--surface);width:64px;height:64px;border-radius:50%;display:grid;place-items:center;box-shadow:inset 3px 3px 6px rgba(120,120,170,.25)}\n  .hab{display:flex;align-items:center;gap:.6rem;background:var(--surface);border-radius:18px;padding:.6rem .8rem;box-shadow:var(--clay);font-size:.9rem}\n  .hab .dot{width:24px;height:24px;border-radius:8px;background:linear-gradient(145deg,var(--c1),var(--c3));box-shadow:var(--clay)}\n  section{padding:4rem 0}\n  h2{text-align:center;font-size:clamp(1.9rem,4vw,2.7rem);font-weight:800;letter-spacing:-.02em;margin:0 0 2.2rem}\n  .feats{display:grid;grid-template-columns:repeat(3,1fr);gap:1.4rem}\n  .feat{background:var(--surface);border-radius:var(--r);padding:1.8rem;box-shadow:var(--clay);text-align:center}\n  .feat .ic{width:60px;height:60px;margin:0 auto .8rem;border-radius:20px;display:grid;place-items:center;font-size:1.6rem;box-shadow:var(--clay)}\n  .i1{background:linear-gradient(145deg,#cdbcff,#b8a6ff)}.i2{background:linear-gradient(145deg,#a6f0db,#88e0c8)}.i3{background:linear-gradient(145deg,#ffd6ea,#ffc7e0)}\n  .feat h3{margin:0 0 .3rem;font-size:1.15rem}.feat p{color:var(--muted);margin:0;font-weight:600}\n  .cta{background:var(--surface);border-radius:40px;box-shadow:var(--clay);text-align:center;padding:3rem 1.5rem}\n  footer{text-align:center;color:var(--muted);padding:2.5rem 0 3rem;font-size:.9rem}\n  .reveal{opacity:0;transform:translateY(22px);transition:opacity .6s,transform .6s cubic-bezier(.2,.8,.2,1)}.reveal.in{opacity:1;transform:none}\n  @media(max-width:840px){.hero{grid-template-columns:1fr;text-align:center}.sub{margin-inline:auto}.ctas{justify-content:center}.feats{grid-template-columns:1fr}.links a:not(.btn){display:none}}\n  @media(prefers-reduced-motion:reduce){.phone{animation:none}.reveal{opacity:1;transform:none;transition:none}html{scroll-behavior:auto}}\n</style>\n</head>\n<body>\n  <div class=\"wrap\">\n    <nav>\n      <div class=\"brand\"><span class=\"blob\"></span> Bloom</div>\n      <div class=\"links\"><a href=\"#\">Features</a><a href=\"#\">Pricing</a><a href=\"#\">Stories</a><a class=\"btn\" href=\"#\">Get the app</a></div>\n    </nav>\n\n    <header class=\"hero\">\n      <div>\n        <span class=\"pill\">🌱 Loved by 500k gentle humans</span>\n        <h1>Tiny habits, <span class=\"g\">big blooms</span>.</h1>\n        <p class=\"sub\">Bloom makes building better routines feel soft and joyful — not another chore on your list.</p>\n        <div class=\"ctas\"><a class=\"btn\" href=\"#\">Download free</a><a class=\"btn mint\" href=\"#\">How it works</a></div>\n      </div>\n      <div class=\"phone\" aria-hidden=\"true\"><div class=\"screen\">\n        <div class=\"top\">Today 🌤️</div>\n        <div class=\"ring\"><b>75%</b></div>\n        <div class=\"hab\"><span class=\"dot\"></span> Drink water</div>\n        <div class=\"hab\"><span class=\"dot\"></span> 10-min walk</div>\n        <div class=\"hab\"><span class=\"dot\"></span> Read a page</div>\n      </div></div>\n    </header>\n  </div>\n\n  <section><div class=\"wrap\">\n    <h2 class=\"reveal\">Soft on you, serious about progress</h2>\n    <div class=\"feats\">\n      <div class=\"feat reveal\"><div class=\"ic i1\">🌼</div><h3>Gentle streaks</h3><p>Miss a day? Bloom forgives — and helps you bounce back.</p></div>\n      <div class=\"feat reveal\"><div class=\"ic i2\">🔔</div><h3>Kind nudges</h3><p>Reminders that feel like a friend, not an alarm.</p></div>\n      <div class=\"feat reveal\"><div class=\"ic i3\">📈</div><h3>Cozy insights</h3><p>Watch your routines grow with warm, simple charts.</p></div>\n    </div>\n  </div></section>\n\n  <section><div class=\"wrap\"><div class=\"cta reveal\">\n    <h2>Start blooming today</h2>\n    <p style=\"color:var(--muted);max-width:40ch;margin:0 auto 1.4rem\">Free forever for one routine. Upgrade whenever you're ready to grow.</p>\n    <a class=\"btn\" href=\"#\">Get Bloom — it's free 🌸</a>\n  </div></div></section>\n\n  <footer>© <span id=\"yr\"></span> Bloom · Be gentle with yourself.</footer>\n  <script>\n    document.getElementById('yr').textContent=new Date().getFullYear();\n    var io=new IntersectionObserver(function(es){es.forEach(function(e){if(e.isIntersecting){e.target.classList.add('in');io.unobserve(e.target)}})},{threshold:.12});\n    document.querySelectorAll('.reveal').forEach(function(el){io.observe(el)});\n  </script>\n</body>\n</html>\n"
}
