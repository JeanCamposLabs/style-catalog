  "source": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Retro-Futurism — Synthwave Game</title>\n<script type=\"application/json\" id=\"effect-meta\">\n{\n  \"id\": \"synthwave-arcade\",\n  \"title\": \"Retro-Futurism — Synthwave Game\",\n  \"summary\": \"An 80s synthwave landing for a game/album: an animated neon perspective grid, chrome-gradient title, sun, and scanlines.\",\n  \"description\": \"Retro-futurism / synthwave is a recurring 2026 aesthetic for games, music, and events — neon, chrome, and that endless perspective grid receding into a gradient sun. This landing has an animated scrolling grid floor, a chrome title with glow, a glassy CTA, a feature row, and CRT scanlines.\",\n  \"theme\": \"website-templates\",\n  \"categories\": [\"template\", \"landing\", \"entertainment\"],\n  \"tags\": [\"synthwave\", \"retro-futurism\", \"80s\", \"neon\", \"game\", \"music\", \"full-page\"],\n  \"tech\": [\"html\", \"css\", \"js\"],\n  \"era\": \"2020s\",\n  \"difficulty\": \"intermediate\",\n  \"dependencies\": [],\n  \"browser_support\": \"All modern browsers (CSS 3D transforms, gradients).\",\n  \"performance_notes\": \"The grid is a CSS gradient with a scrolling background-position animation; scanlines are a repeating gradient overlay. No images or libraries.\",\n  \"accessibility_notes\": \"Text glow kept readable; scanlines are subtle and pointer-events:none; grid scroll and glow pulse stop under reduced-motion.\",\n  \"customization\": [\n    { \"name\": \"--neon/--neon2\", \"description\": \"Grid + glow colors\", \"default\": \"magenta / cyan\" },\n    { \"name\": \"grid speed\", \"description\": \"Background-position animation duration\", \"default\": \"3s\" }\n  ],\n  \"variations\": [\"Daytime palette (teal/orange)\", \"Drop scanlines for a cleaner look\", \"Add a real character/3D render over the grid\"],\n  \"related\": [\"perspective-grid\", \"neon-glow\", \"scanlines\", \"reveal-on-scroll\"],\n  \"ai_usage\": \"Use for games, synth/electronic music, retro events, arcades. The signature is the perspective grid (a linear-gradient grid skewed with transform: rotateX) scrolling toward the viewer, plus a gradient 'sun' and chrome text. Recolor via --neon/--neon2. Replace the title and feature copy. Reduced-motion safe.\"\n}\n</script>\n<style>\n  :root{--bg:#10021f;--text:#ffe9fb;--muted:#b79fcf;--neon:#ff2bd6;--neon2:#2bf0ff;--sun1:#ff8a3d;--sun2:#ff2bd6;}\n  *{box-sizing:border-box}html{scroll-behavior:smooth}\n  body{margin:0;background:var(--bg);color:var(--text);font-family:\"Orbitron\",\"Audiowide\",system-ui,sans-serif;line-height:1.6;overflow-x:hidden;position:relative}\n  a{color:inherit;text-decoration:none}\n  /* scanlines */\n  body::after{content:\"\";position:fixed;inset:0;pointer-events:none;z-index:50;background:repeating-linear-gradient(transparent 0 2px,rgba(0,0,0,.18) 2px 3px);mix-blend-mode:multiply}\n  .wrap{max-width:1080px;margin:0 auto;padding:0 1.4rem;position:relative;z-index:2}\n  nav{display:flex;align-items:center;justify-content:space-between;height:70px}\n  .brand{font-weight:700;letter-spacing:.12em;color:var(--neon2);text-shadow:0 0 12px var(--neon2)}\n  .links{display:flex;gap:1.3rem;align-items:center;font-size:.85rem;letter-spacing:.08em;color:var(--muted)}.links a:hover{color:#fff;text-shadow:0 0 8px var(--neon)}\n  .btn{display:inline-block;font-family:inherit;font-weight:700;letter-spacing:.08em;border:2px solid var(--neon2);color:var(--neon2);background:rgba(43,240,255,.08);border-radius:6px;padding:.55rem 1.2rem;cursor:pointer;text-shadow:0 0 8px var(--neon2);box-shadow:0 0 16px rgba(43,240,255,.4),inset 0 0 12px rgba(43,240,255,.15);transition:transform .15s}\n  .btn:hover{transform:translateY(-2px)}\n  .btn.pink{border-color:var(--neon);color:var(--neon);background:rgba(255,43,214,.08);text-shadow:0 0 8px var(--neon);box-shadow:0 0 16px rgba(255,43,214,.4),inset 0 0 12px rgba(255,43,214,.15)}\n  .btn:focus-visible{outline:2px solid #fff;outline-offset:3px}\n  .stage{position:relative;text-align:center;padding:5rem 0 0;overflow:hidden}\n  .sun{position:absolute;left:50%;top:42%;transform:translate(-50%,-50%);width:340px;height:340px;border-radius:50%;\n    background:linear-gradient(180deg,var(--sun1),var(--sun2));filter:blur(2px);z-index:0;\n    -webkit-mask:repeating-linear-gradient(#000 0 8px,transparent 8px 14px);mask:repeating-linear-gradient(#000 0 8px,transparent 8px 14px);animation:pulse 4s ease-in-out infinite}\n  @keyframes pulse{50%{filter:blur(6px) brightness(1.15)}}\n  .title{position:relative;z-index:2;font-size:clamp(2.6rem,11vw,7rem);font-weight:700;letter-spacing:.04em;line-height:.95;margin:0;\n    background:linear-gradient(180deg,#fff 0%,#ffd1f6 40%,var(--neon) 60%,#8a1fb0 100%);-webkit-background-clip:text;background-clip:text;color:transparent;\n    filter:drop-shadow(0 2px 0 #3a0c4a) drop-shadow(0 0 22px rgba(255,43,214,.6))}\n  .tag{position:relative;z-index:2;color:var(--muted);letter-spacing:.18em;text-transform:uppercase;font-size:.82rem;margin-top:1rem}\n  .ctas{position:relative;z-index:2;display:flex;gap:1rem;justify-content:center;margin:2rem 0 1rem;flex-wrap:wrap}\n  /* grid floor */\n  .floor{position:relative;height:300px;margin-top:1rem;perspective:300px;overflow:hidden}\n  .grid{position:absolute;inset:-50% 0 0;transform:rotateX(72deg);transform-origin:top center;\n    background-image:linear-gradient(var(--neon2) 2px,transparent 2px),linear-gradient(90deg,var(--neon2) 2px,transparent 2px);\n    background-size:46px 46px;opacity:.5;animation:scroll 3s linear infinite}\n  @keyframes scroll{to{background-position:0 46px}}\n  .floor::after{content:\"\";position:absolute;inset:0;background:linear-gradient(180deg,var(--bg) 0%,transparent 30%,transparent 70%,var(--bg) 100%)}\n  section{padding:4rem 0}\n  h2{text-align:center;font-size:clamp(1.6rem,4vw,2.4rem);letter-spacing:.06em;color:var(--neon2);text-shadow:0 0 14px rgba(43,240,255,.5);margin:0 0 2rem}\n  .feats{display:grid;grid-template-columns:repeat(3,1fr);gap:1.2rem}\n  .feat{border:1px solid rgba(255,43,214,.3);background:rgba(255,43,214,.05);border-radius:10px;padding:1.5rem;box-shadow:inset 0 0 24px rgba(255,43,214,.08)}\n  .feat .ic{font-size:1.8rem}.feat h3{margin:.5rem 0 .3rem;letter-spacing:.04em;font-size:1.05rem;color:#fff}.feat p{color:var(--muted);margin:0;font-family:system-ui,sans-serif;font-size:.92rem;letter-spacing:0}\n  footer{text-align:center;color:var(--muted);padding:2.5rem 0 3rem;font-size:.8rem;letter-spacing:.1em}\n  .reveal{opacity:0;transform:translateY(22px);transition:opacity .7s,transform .7s ease}.reveal.in{opacity:1;transform:none}\n  @media(max-width:780px){.feats{grid-template-columns:1fr}.links a:not(.btn){display:none}}\n  @media(prefers-reduced-motion:reduce){.grid,.sun{animation:none}.reveal{opacity:1;transform:none;transition:none}html{scroll-behavior:auto}}\n</style>\n</head>\n<body>\n  <div class=\"wrap\">\n    <nav>\n      <div class=\"brand\">▶ NEON DRIFT</div>\n      <div class=\"links\"><a href=\"#\">Game</a><a href=\"#\">Soundtrack</a><a href=\"#\">News</a><a class=\"btn pink\" href=\"#\">Wishlist</a></div>\n    </nav>\n  </div>\n\n  <header class=\"stage\">\n    <div class=\"sun\" aria-hidden=\"true\"></div>\n    <div class=\"wrap\">\n      <h1 class=\"title\">NEON<br>DRIFT</h1>\n      <p class=\"tag\">A high-speed retrowave racer · Coming 2026</p>\n      <div class=\"ctas\"><a class=\"btn\" href=\"#\">Play the demo</a><a class=\"btn pink\" href=\"#\">Wishlist on Steam</a></div>\n    </div>\n    <div class=\"floor\" aria-hidden=\"true\"><div class=\"grid\"></div></div>\n  </header>\n\n  <section class=\"wrap\">\n    <h2 class=\"reveal\">Built for the night</h2>\n    <div class=\"feats\">\n      <div class=\"feat reveal\"><div class=\"ic\">🏎️</div><h3>Outrun physics</h3><p>Drift through endless neon highways at 300km/h.</p></div>\n      <div class=\"feat reveal\"><div class=\"ic\">🎵</div><h3>Original synth OST</h3><p>40 tracks of pure 1986 nostalgia.</p></div>\n      <div class=\"feat reveal\"><div class=\"ic\">🏆</div><h3>Online ladders</h3><p>Race ghosts and climb the global boards.</p></div>\n    </div>\n  </section>\n\n  <footer class=\"wrap\">© <span id=\"yr\"></span> NEON DRIFT · INSERT COIN TO CONTINUE</footer>\n  <script>\n    document.getElementById('yr').textContent=new Date().getFullYear();\n    var io=new IntersectionObserver(function(es){es.forEach(function(e){if(e.isIntersecting){e.target.classList.add('in');io.unobserve(e.target)}})},{threshold:.15});\n    document.querySelectorAll('.reveal').forEach(function(el){io.observe(el)});\n  </script>\n</body>\n</html>\n"
}
