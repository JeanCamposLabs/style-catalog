  "ai_usage": "Show in place of content during data fetches; match block shapes/sizes to the real layout to avoid reflow jank. Apply .skeleton to each placeholder; it tiles a 3-stop gradient (base, sheen, base) at background-size:200% and animates background-position. Set aria-busy on the container, then swap in real content when loaded.",
  "path": "effects/loaders-spinners/skeleton-loader.html",
  "source": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>Skeleton Loader</title>\n  <script type=\"application/json\" id=\"effect-meta\">\n  {\n    \"id\": \"skeleton-loader\",\n    \"title\": \"Skeleton Loader\",\n    \"summary\": \"Gray placeholder blocks with a sweeping shimmer that mimic content while it loads.\",\n    \"description\": \"Content-shaped gray boxes get a moving highlight gradient (the same trick as shimmer text) to signal that real content is on its way — reducing perceived load time.\",\n    \"theme\": \"loaders-spinners\",\n    \"categories\": [\"loader\", \"skeleton\", \"placeholder\"],\n    \"tags\": [\"skeleton\", \"shimmer\", \"placeholder\", \"loading\", \"ghost\", \"content\"],\n    \"tech\": [\"css\"],\n    \"era\": \"2020s\",\n    \"difficulty\": \"beginner\",\n    \"dependencies\": [],\n    \"browser_support\": \"All modern browsers.\",\n    \"performance_notes\": \"Animates background-position only; cheap even for many blocks.\",\n    \"accessibility_notes\": \"Mark the region aria-busy=\\\"true\\\" and/or role=status so assistive tech announces loading. Shimmer stops under prefers-reduced-motion (static gray).\",\n    \"customization\": [\n      { \"name\": \"--base\", \"description\": \"Block color\", \"default\": \"#1b2030\" },\n      { \"name\": \"--sheen\", \"description\": \"Shimmer highlight\", \"default\": \"#2a3142\" }\n    ],\n    \"variations\": [\"Circle skeleton for avatars\", \"Card skeleton (image + lines)\", \"Pulse opacity instead of shimmer sweep\"],\n    \"related\": [\"shimmer-text\"],\n    \"ai_usage\": \"Show in place of content during data fetches; match block shapes/sizes to the real layout to avoid reflow jank. Apply .skeleton to each placeholder; it tiles a 3-stop gradient (base, sheen, base) at background-size:200% and animates background-position. Set aria-busy on the container, then swap in real content when loaded.\"\n  }\n  </script>\n  <style>\n    :root { --base: #1b2030; --sheen: #2a3142; }\n    html, body { height: 100%; margin: 0; }\n    body { display: grid; place-items: center; background: #0b0d12; font-family: system-ui, sans-serif; }\n    .card { width: 300px; padding: 1.2rem; border-radius: 14px; background: #11141c; border: 1px solid #262c3d; }\n    .skeleton {\n      background: linear-gradient(100deg, var(--base) 30%, var(--sheen) 50%, var(--base) 70%);\n      background-size: 200% 100%; border-radius: 8px; animation: shine 1.4s linear infinite;\n    }\n    .s-avatar { width: 52px; height: 52px; border-radius: 50%; margin-bottom: 1rem; }\n    .s-line { height: 12px; margin-bottom: .7rem; }\n    .s-line.w80 { width: 80%; } .s-line.w60 { width: 60%; } .s-line.w100 { width: 100%; }\n    @keyframes shine { to { background-position: -200% 0; } }\n    @media (prefers-reduced-motion: reduce) { .skeleton { animation: none; background: var(--base); } }\n  </style>\n</head>\n<body>\n  <div class=\"card\" role=\"status\" aria-busy=\"true\" aria-label=\"Loading content\">\n    <div class=\"skeleton s-avatar\"></div>\n    <div class=\"skeleton s-line w80\"></div>\n    <div class=\"skeleton s-line w100\"></div>\n    <div class=\"skeleton s-line w60\"></div>\n  </div>\n</body>\n</html>\n"
}
