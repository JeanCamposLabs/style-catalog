  "source": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>Claymorphism Card</title>\n  <script type=\"application/json\" id=\"effect-meta\">\n  {\n    \"id\": \"claymorphism-card\",\n    \"title\": \"Claymorphism Card\",\n    \"summary\": \"A puffy, candy-like 3D clay surface with big radii and inset highlights.\",\n    \"description\": \"Combines very large border-radius, a flat fill, a soft drop shadow, and two inset shadows (a bright top-inner and a darker bottom-inner) to make elements look like inflated soft clay.\",\n    \"theme\": \"glass-neumorphism\",\n    \"categories\": [\"surface\", \"claymorphism\", \"card\"],\n    \"tags\": [\"claymorphism\", \"clay\", \"puffy\", \"3d\", \"playful\", \"inset-shadow\"],\n    \"tech\": [\"css\"],\n    \"era\": \"2020s\",\n    \"difficulty\": \"beginner\",\n    \"dependencies\": [],\n    \"browser_support\": \"All browsers.\",\n    \"performance_notes\": \"Static multi-shadow; trivial.\",\n    \"accessibility_notes\": \"Generally good contrast since fills are solid and bold; keep text legible on the chosen fill.\",\n    \"customization\": [\n      { \"name\": \"--clay\", \"description\": \"Fill color\", \"default\": \"#7c5cff\" },\n      { \"name\": \"--radius\", \"description\": \"Corner roundness\", \"default\": \"44px\" }\n    ],\n    \"variations\": [\"Pastel palette for kid/edu apps\", \"Clay buttons & icons\", \"Combine with a floating-bob animation\"],\n    \"related\": [\"neumorphism-card\", \"glassmorphism-card\"],\n    \"ai_usage\": \"Playful, friendly UIs (education, kids, casual apps). Recipe: large border-radius, solid fill, an outer drop shadow for lift, plus TWO inset shadows — a light one (top-left, simulating a highlight) and a darker tinted one (bottom-right). Increase radius and shadow softness for puffier clay. Pairs well with bright, saturated palettes.\"\n  }\n  </script>\n  <style>\n    :root { --clay: #7c5cff; --radius: 44px; }\n    html, body { height: 100%; margin: 0; }\n    body { display: grid; place-items: center; background: #eef0ff; font-family: system-ui, sans-serif; }\n    .clay {\n      width: 220px; height: 220px; border-radius: var(--radius); background: var(--clay);\n      display: grid; place-items: center; color: #fff; font-weight: 800; font-size: 1.2rem;\n      box-shadow:\n        0 18px 40px rgba(124,92,255,.45),\n        inset 8px 8px 16px rgba(255,255,255,.45),\n        inset -10px -12px 22px rgba(60,40,140,.55);\n    }\n  </style>\n</head>\n<body>\n  <div class=\"clay\">Clay</div>\n</body>\n</html>\n"
