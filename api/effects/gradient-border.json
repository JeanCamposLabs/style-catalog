    "gradient"
  ],
  "tags": [
    "gradient",
    "border",
    "border-box",
    "outline",
    "rounded"
  ],
  "tech": [
    "css"
  ],
  "era": "2020s",
  "difficulty": "intermediate",
  "dependencies": [],
  "browser_support": "All modern browsers. (border-image can't do rounded corners, hence this technique.)",
  "performance_notes": "Static; free.",
  "accessibility_notes": "Decorative border; keep inner content contrast independent of the border.",
  "customization": [
    {
      "name": "--bg",
      "description": "Inner fill",
      "default": "#11141c"
    },
    {
      "name": "--grad",
      "description": "Border gradient",
      "default": "linear-gradient(135deg,#7c5cff,#2dd4bf)"
    },
    {
      "name": "--bw",
      "description": "Border width",
      "default": "2px"
