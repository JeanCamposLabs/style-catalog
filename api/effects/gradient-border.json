{
  "id": "gradient-border",
  "title": "Gradient Border",
  "summary": "A crisp gradient outline on a rounded element using the double-background trick.",
  "description": "Layers a solid background (padding-box) over a gradient background (border-box) with a transparent border, so the gradient shows only in the border area — the reliable way to get gradient borders with border-radius.",
  "theme": "borders-shadows",
  "themeTitle": "Borders & Shadows",
  "categories": [
