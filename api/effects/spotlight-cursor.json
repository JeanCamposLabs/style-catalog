  "ai_usage": "Playful 'reveal in the dark' microsites and easter eggs — NOT for essential content. A fixed overlay sits above content with background var(--dim) and a radial-gradient mask: mask: radial-gradient(circle var(--r) at var(--x) var(--y), transparent 99%, #000). Update --x/--y on pointermove. Always provide an accessible, non-masked path to the same content.",
  "path": "effects/cursors-pointers/spotlight-cursor.html",
  "source": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>Cursor Spotlight Reveal</title>\n  <script type=\"application/json\" id=\"effect-meta\">\n  {\n    \"id\": \"spotlight-cursor\",\n    \"title\": \"Cursor Spotlight Reveal\",\n    \"summary\": \"The cursor carries a spotlight that reveals hidden content through a dark mask.\",\n    \"description\": \"A full-screen overlay uses a radial-gradient mask centered on the cursor, so only a circle around the pointer is illuminated — a flashlight/torch reveal over otherwise dimmed content.\",\n    \"theme\": \"cursors-pointers\",\n    \"categories\": [\"cursor\", \"reveal\", \"mask\"],\n    \"tags\": [\"spotlight\", \"flashlight\", \"torch\", \"mask\", \"reveal\", \"cursor\"],\n    \"tech\": [\"css\", \"js\"],\n    \"era\": \"2020s\",\n    \"difficulty\": \"intermediate\",\n    \"dependencies\": [],\n    \"browser_support\": \"All modern browsers (radial-gradient mask). Prefix mask for older Safari.\",\n    \"performance_notes\": \"Updates two CSS variables on pointermove; the mask is GPU-composited. Cheap.\",\n    \"accessibility_notes\": \"Hiding content behind a cursor mask is bad for keyboard/screen-reader users and anyone who can't aim precisely — only use for playful, non-essential reveals and provide an accessible alternative.\",\n    \"customization\": [\n      { \"name\": \"--r\", \"description\": \"Spotlight radius\", \"default\": \"120px\" },\n      { \"name\": \"--dim\", \"description\": \"How dark the masked area is\", \"default\": \"rgba(0,0,0,.92)\" }\n    ],\n    \"variations\": [\"Reveal an image layer instead of text\", \"Soft vs hard spotlight edge\", \"Multiple lights for collaborative cursors\"],\n    \"related\": [\"follow-dot-cursor\", \"spotlight-card\"],\n    \"ai_usage\": \"Playful 'reveal in the dark' microsites and easter eggs — NOT for essential content. A fixed overlay sits above content with background var(--dim) and a radial-gradient mask: mask: radial-gradient(circle var(--r) at var(--x) var(--y), transparent 99%, #000). Update --x/--y on pointermove. Always provide an accessible, non-masked path to the same content.\"\n  }\n  </script>\n  <style>\n    :root { --x: 50%; --y: 50%; --r: 120px; --dim: rgba(0,0,0,.92); }\n    html, body { height: 100%; margin: 0; }\n    body { display: grid; place-items: center; background: #0b0d12; color: #2dd4bf; font-family: system-ui, sans-serif; }\n    .hidden-text { font-size: 2rem; font-weight: 800; text-align: center; padding: 1rem; }\n    .torch {\n      position: fixed; inset: 0; pointer-events: none; background: var(--dim);\n      -webkit-mask: radial-gradient(circle var(--r) at var(--x) var(--y), transparent 98%, #000 100%);\n      mask: radial-gradient(circle var(--r) at var(--x) var(--y), transparent 98%, #000 100%);\n    }\n  </style>\n</head>\n<body>\n  <div class=\"hidden-text\">Move the light<br>to find me ✨</div>\n  <div class=\"torch\" id=\"torch\"></div>\n  <script>\n    var t = document.getElementById(\"torch\");\n    addEventListener(\"pointermove\", function (e) {\n      t.style.setProperty(\"--x\", e.clientX + \"px\");\n      t.style.setProperty(\"--y\", e.clientY + \"px\");\n    });\n  </script>\n</body>\n</html>\n"
}
