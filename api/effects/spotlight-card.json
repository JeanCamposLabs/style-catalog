  "ai_usage": "Excellent for feature/pricing card grids. Set --x/--y from the cursor position on pointermove and paint a radial-gradient at (var(--x), var(--y)). For a grid, attach the listener to the container and read event.target to update the right card, or update each card from the shared mouse position to get the 'group spotlight' effect. No reduced-motion concern but keep it subtle.",
  "path": "effects/hover-interactions/spotlight-card.html",
  "source": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>Spotlight Hover Card</title>\n  <script type=\"application/json\" id=\"effect-meta\">\n  {\n    \"id\": \"spotlight-card\",\n    \"title\": \"Spotlight Hover Card\",\n    \"summary\": \"A soft radial spotlight follows the cursor across the card surface.\",\n    \"description\": \"Tracks the pointer and updates CSS variables for a radial-gradient glow that reveals as the cursor moves — the interactive card look popularized by modern dev-tool landing pages.\",\n    \"theme\": \"hover-interactions\",\n    \"categories\": [\"hover\", \"card\", \"glow\"],\n    \"tags\": [\"spotlight\", \"cursor\", \"glow\", \"radial\", \"card\", \"reveal\"],\n    \"tech\": [\"css\", \"js\"],\n    \"era\": \"2020s\",\n    \"difficulty\": \"beginner\",\n    \"dependencies\": [],\n    \"browser_support\": \"All modern browsers.\",\n    \"performance_notes\": \"Only updates two CSS variables on pointermove; very cheap. Scales to a grid with one delegated handler.\",\n    \"accessibility_notes\": \"Decorative enhancement; content fully readable without it. No motion concerns (no looping animation).\",\n    \"customization\": [\n      { \"name\": \"--spot\", \"description\": \"Spotlight color\", \"default\": \"rgba(124,92,255,.25)\" },\n      { \"name\": \"--spot-size\", \"description\": \"Spotlight radius\", \"default\": \"200px\" }\n    ],\n    \"variations\": [\"Border-only spotlight (mask the glow to the edge)\", \"Group hover: highlight only the hovered card in a grid\", \"Pair with the tilt-card effect\"],\n    \"related\": [\"tilt-card\", \"card-lift\"],\n    \"ai_usage\": \"Excellent for feature/pricing card grids. Set --x/--y from the cursor position on pointermove and paint a radial-gradient at (var(--x), var(--y)). For a grid, attach the listener to the container and read event.target to update the right card, or update each card from the shared mouse position to get the 'group spotlight' effect. No reduced-motion concern but keep it subtle.\"\n  }\n  </script>\n  <style>\n    :root { --spot: rgba(124,92,255,.35); --spot-size: 220px; }\n    html, body { height: 100%; margin: 0; }\n    body { display: grid; place-items: center; background: #0b0d12; font-family: system-ui, sans-serif; }\n    .spotlight {\n      position: relative; width: 260px; height: 320px; border-radius: 18px; overflow: hidden;\n      background: #14182360; border: 1px solid #262c3d; color: #e7ebf3;\n      display: grid; place-items: center; padding: 1.2rem; text-align: center;\n    }\n    .spotlight::before {\n      content: \"\"; position: absolute; inset: 0; pointer-events: none; opacity: 0; transition: opacity .3s;\n      background: radial-gradient(var(--spot-size) circle at var(--x,50%) var(--y,50%), var(--spot), transparent 60%);\n    }\n    .spotlight:hover::before { opacity: 1; }\n  </style>\n</head>\n<body>\n  <div class=\"spotlight\" id=\"card\">\n    <div>\n      <h3 style=\"margin:.3rem\">Spotlight</h3>\n      <p style=\"margin:.3rem;color:#8b93a7\">Hover to light it up</p>\n    </div>\n  </div>\n  <script>\n    var card = document.getElementById(\"card\");\n    card.addEventListener(\"pointermove\", function (e) {\n      var r = card.getBoundingClientRect();\n      card.style.setProperty(\"--x\", (e.clientX - r.left) + \"px\");\n      card.style.setProperty(\"--y\", (e.clientY - r.top) + \"px\");\n    });\n  </script>\n</body>\n</html>\n"
}
