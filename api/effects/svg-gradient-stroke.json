  ],
  "ai_usage": "Use for premium loaders and progress rings. Stroke a <circle> with url(#gradient); set stroke-linecap='round'. For an indeterminate spinner, animate the whole SVG's rotation AND the stroke-dasharray/dashoffset (Material-style). For determinate progress, fix dasharray to the circumference and set dashoffset from your percentage. Rotate the SVG element, not the gradient (gradients are in user space). Add role=status + label when it's a loader.",
  "path": "effects/svg-effects/svg-gradient-stroke.html",
  "source": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>SVG Animated Gradient Stroke</title>\n  <script type=\"application/json\" id=\"effect-meta\">\n  {\n    \"id\": \"svg-gradient-stroke\",\n    \"title\": \"SVG Animated Gradient Stroke\",\n    \"summary\": \"A circular progress/loader ring stroked with a gradient and an animating dash.\",\n    \"description\": \"Combines an SVG linearGradient stroke with stroke-linecap round and an animated stroke-dasharray/dashoffset to create a smooth gradient-stroked spinner or progress arc.\",\n    \"theme\": \"svg-effects\",\n    \"categories\": [\"svg\", \"stroke\", \"loader\"],\n    \"tags\": [\"svg\", \"gradient-stroke\", \"spinner\", \"progress\", \"dash\", \"loader\"],\n    \"tech\": [\"svg\", \"css\"],\n    \"era\": \"2020s\",\n    \"difficulty\": \"intermediate\",\n    \"dependencies\": [],\n    \"browser_support\": \"All modern browsers. Note: SVG gradient stroke doesn't rotate with the element, so rotate the whole SVG, not the gradient.\",\n    \"performance_notes\": \"Animating rotation + dash via CSS is cheap.\",\n    \"accessibility_notes\": \"If used as a loader, wrap with role=status + a visually-hidden label. Slow under prefers-reduced-motion rather than stopping (it's a busy indicator).\",\n    \"customization\": [\n      { \"name\": \"gradient stops\", \"description\": \"Stroke colors\", \"default\": \"#7c5cff → #2dd4bf\" },\n      { \"name\": \"stroke-width\", \"description\": \"Ring thickness\", \"default\": \"10\" }\n    ],\n    \"variations\": [\"Determinate progress (set dashoffset from a value)\", \"Conic-like full-rainbow stroke\", \"Pulsing dash length\"],\n    \"related\": [\"progress-ring\", \"ring-spinner\", \"gradient-border\"],\n    \"ai_usage\": \"Use for premium loaders and progress rings. Stroke a <circle> with url(#gradient); set stroke-linecap='round'. For an indeterminate spinner, animate the whole SVG's rotation AND the stroke-dasharray/dashoffset (Material-style). For determinate progress, fix dasharray to the circumference and set dashoffset from your percentage. Rotate the SVG element, not the gradient (gradients are in user space). Add role=status + label when it's a loader.\"\n  }\n  </script>\n  <style>\n    html, body { height: 100%; margin: 0; }\n    body { display: grid; place-items: center; background: #0b0d12; }\n    .spin { animation: rotate 2s linear infinite; }\n    .arc { stroke: url(#gs); stroke-width: 10; fill: none; stroke-linecap: round;\n      stroke-dasharray: 200; animation: dash 1.6s ease-in-out infinite; }\n    @keyframes rotate { to { transform: rotate(360deg); } }\n    @keyframes dash {\n      0% { stroke-dashoffset: 190; }\n      50% { stroke-dashoffset: 50; }\n      100% { stroke-dashoffset: 190; }\n    }\n    @media (prefers-reduced-motion: reduce) { .spin { animation-duration: 5s; } .arc { animation-duration: 4s; } }\n    .visually-hidden { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0 0 0 0); }\n  </style>\n</head>\n<body>\n  <div role=\"status\">\n    <svg class=\"spin\" width=\"90\" height=\"90\" viewBox=\"0 0 80 80\">\n      <defs>\n        <linearGradient id=\"gs\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">\n          <stop offset=\"0%\" stop-color=\"#7c5cff\" /><stop offset=\"100%\" stop-color=\"#2dd4bf\" />\n        </linearGradient>\n      </defs>\n      <circle class=\"arc\" cx=\"40\" cy=\"40\" r=\"32\" />\n    </svg>\n    <span class=\"visually-hidden\">Loading…</span>\n  </div>\n</body>\n</html>\n"
}
