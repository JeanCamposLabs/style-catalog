  "path": "effects/website-templates/kinetic-portfolio.html",
  "source": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Kinetic Type — Creative Portfolio</title>\n<script type=\"application/json\" id=\"effect-meta\">\n{\n  \"id\": \"kinetic-portfolio\",\n  \"title\": \"Kinetic Type — Creative Portfolio\",\n  \"summary\": \"A bold creative-director portfolio led by kinetic typography: a cursor-reactive hero headline and an infinite marquee, on stark black.\",\n  \"description\": \"Kinetic typography — text that moves and reacts — is a defining 2026 hero treatment. This portfolio opens with a massive headline whose words tilt and shift toward the cursor, backed by a high-speed marquee strip, then a minimal work list. Stark, confident, motion-first.\",\n  \"theme\": \"website-templates\",\n  \"categories\": [\"template\", \"portfolio\", \"creative\"],\n  \"tags\": [\"kinetic-typography\", \"marquee\", \"portfolio\", \"creative\", \"dark\", \"interactive\", \"2026-trend\", \"full-page\"],\n  \"tech\": [\"html\", \"css\", \"js\"],\n  \"era\": \"2020s\",\n  \"difficulty\": \"intermediate\",\n  \"dependencies\": [],\n  \"browser_support\": \"All modern browsers (pointer events, CSS transforms).\",\n  \"performance_notes\": \"One rAF-free pointermove handler (throttled via CSS transitions) + a CSS marquee. Lightweight.\",\n  \"accessibility_notes\": \"Headline remains readable text; motion is decorative. Marquee and cursor-reaction disable under prefers-reduced-motion. Focus-visible on links.\",\n  \"customization\": [\n    { \"name\": \"--accent\", \"description\": \"The single accent\", \"default\": \"#d6ff3f\" },\n    { \"name\": \"reaction strength\", \"description\": \"Multiplier in JS (max tilt/shift)\", \"default\": \"moderate\" }\n  ],\n  \"variations\": [\"Light version (invert)\", \"Replace marquee with a second kinetic line\", \"Per-letter reaction instead of per-word\"],\n  \"related\": [\"kinetic-typography\", \"marquee-scroll\", \"magnetic-button\"],\n  \"ai_usage\": \"Use for creative directors, motion designers, studios. The hero words are spans translated/rotated by the cursor's offset from center via a pointermove handler; CSS transitions smooth it. Keep one accent color and lots of black. Replace the headline words, marquee text, and work rows. All motion is reduced-motion guarded.\"\n}\n</script>\n<style>\n  :root{--bg:#0c0c0c;--text:#f5f5f0;--muted:#8a8a82;--accent:#d6ff3f;}\n  *{box-sizing:border-box}html{scroll-behavior:smooth}\n  body{margin:0;background:var(--bg);color:var(--text);font-family:\"Archivo\",\"Helvetica Neue\",Arial,sans-serif;line-height:1.2;overflow-x:hidden}\n  a{color:inherit;text-decoration:none}\n  .wrap{max-width:1280px;margin:0 auto;padding:0 1.6rem}\n  nav{display:flex;justify-content:space-between;align-items:center;padding:1.4rem 0;mix-blend-mode:difference}\n  .brand{font-weight:800;letter-spacing:-.02em}\n  nav a{margin-left:1.4rem;font-size:.9rem;color:var(--muted)}nav a:hover{color:var(--text)}\n  .hero{padding:6vw 0 2vw;text-align:center}\n  .kinetic{font-size:clamp(3rem,15vw,12rem);font-weight:900;letter-spacing:-.05em;line-height:.85;text-transform:uppercase;margin:0;perspective:800px}\n  .kinetic .w{display:inline-block;transition:transform .25s cubic-bezier(.2,.8,.2,1);will-change:transform}\n  .kinetic .w.acc{color:var(--accent)}\n  .kinetic .w em{font-style:italic;font-weight:400}\n  .tag{max-width:54ch;margin:2rem auto 0;color:var(--muted);font-size:1.15rem;line-height:1.5}\n  .marquee{margin:3vw 0;border-top:1px solid #222;border-bottom:1px solid #222;overflow:hidden;white-space:nowrap;padding:.6rem 0}\n  .marquee .track{display:inline-block;animation:scroll 22s linear infinite;font-size:clamp(1.4rem,4vw,2.6rem);font-weight:800;text-transform:uppercase;letter-spacing:-.02em}\n  .marquee .track span{margin:0 1.5rem}.marquee .track .dot{color:var(--accent)}\n  @keyframes scroll{to{transform:translateX(-50%)}}\n  section{padding:5vw 0}\n  .lbl{font-size:.8rem;text-transform:uppercase;letter-spacing:.16em;color:var(--muted);margin-bottom:1rem}\n  .work a{display:grid;grid-template-columns:1fr auto;gap:1rem;align-items:center;padding:1.6rem 0;border-top:1px solid #1e1e1e;font-size:clamp(1.6rem,5vw,3.4rem);font-weight:800;letter-spacing:-.02em;transition:padding-left .3s,color .3s}\n  .work a:hover{padding-left:1.2rem;color:var(--accent)}\n  .work a .meta{font-size:.95rem;color:var(--muted);font-weight:400}\n  footer{padding:4vw 0 4rem;display:flex;justify-content:space-between;flex-wrap:wrap;gap:1rem;color:var(--muted);border-top:1px solid #1e1e1e;font-size:.95rem}\n  footer a{color:var(--accent)}\n  @media(prefers-reduced-motion:reduce){.kinetic .w{transition:none!important;transform:none!important}.marquee .track{animation:none}html{scroll-behavior:auto}}\n</style>\n</head>\n<body>\n  <div class=\"wrap\">\n    <nav><div class=\"brand\">RÍAN ☻ FOX</div><div><a href=\"#work\">Work</a><a href=\"#info\">Info</a><a href=\"#contact\">Contact</a></div></nav>\n    <header class=\"hero\">\n      <h1 class=\"kinetic\" id=\"k\" aria-label=\"Designer who makes brands move\">\n        <span class=\"w\">Designer</span> <span class=\"w\">who</span><br>\n        <span class=\"w\">makes</span> <span class=\"w acc\">brands</span> <span class=\"w\"><em>move.</em></span>\n      </h1>\n      <p class=\"tag\">Independent creative director &amp; motion designer crafting identities and interfaces with rhythm, weight, and a little chaos.</p>\n    </header>\n  </div>\n\n  <div class=\"marquee\" aria-hidden=\"true\"><div class=\"track\">\n    <span>BRANDING</span><span class=\"dot\">✺</span><span>MOTION</span><span class=\"dot\">✺</span><span>ART DIRECTION</span><span class=\"dot\">✺</span><span>WEB</span><span class=\"dot\">✺</span>\n    <span>BRANDING</span><span class=\"dot\">✺</span><span>MOTION</span><span class=\"dot\">✺</span><span>ART DIRECTION</span><span class=\"dot\">✺</span><span>WEB</span><span class=\"dot\">✺</span>\n  </div></div>\n\n  <section class=\"wrap\" id=\"work\">\n    <div class=\"lbl\">Selected work</div>\n    <div class=\"work\">\n      <a href=\"#\"><span>Hyper&nbsp;Sans</span><span class=\"meta\">Type · 2026</span></a>\n      <a href=\"#\"><span>Voltage&nbsp;Energy</span><span class=\"meta\">Brand · 2025</span></a>\n      <a href=\"#\"><span>Nocturne&nbsp;Records</span><span class=\"meta\">Identity · 2025</span></a>\n      <a href=\"#\"><span>Kestrel&nbsp;App</span><span class=\"meta\">Product · 2024</span></a>\n    </div>\n  </section>\n\n  <footer class=\"wrap\" id=\"contact\">\n    <span>Open for collaborations — <a href=\"mailto:hi@rianfox.studio\">hi@rianfox.studio</a></span>\n    <span>© <span id=\"yr\"></span> Rían Fox</span>\n  </footer>\n\n  <script>\n    document.getElementById('yr').textContent=new Date().getFullYear();\n    var reduce=matchMedia('(prefers-reduced-motion: reduce)').matches;\n    if(!reduce){\n      var ws=[].slice.call(document.querySelectorAll('#k .w'));\n      addEventListener('pointermove',function(e){\n        var cx=innerWidth/2, cy=innerHeight/2;\n        var dx=(e.clientX-cx)/cx, dy=(e.clientY-cy)/cy;\n        ws.forEach(function(w,i){\n          var f=((i%3)+1)*4; // varied strength per word\n          w.style.transform='translate('+(dx*f)+'px,'+(dy*f)+'px) rotate('+(dx*(i%2?2:-2))+'deg)';\n        });\n      });\n    }\n  </script>\n</body>\n</html>\n"
}
