  "ai_usage": "Use for 2FA, email/phone verification, and PIN entry. Render N inputs with inputmode='numeric', maxlength=1, and autocomplete='one-time-code' on the first (for OS autofill). On input, move focus to the next; on Backspace when empty, focus the previous; on paste, distribute digits across boxes. Wrap in a labeled group, keep focus-visible, and announce completion via an aria-live region.",
  "path": "effects/forms-inputs/otp-input.html",
  "source": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>OTP / Verification Code Input</title>\n  <script type=\"application/json\" id=\"effect-meta\">\n  {\n    \"id\": \"otp-input\",\n    \"title\": \"OTP / Verification Code Input\",\n    \"summary\": \"A segmented one-time-code field: type to auto-advance, backspace to go back, paste to fill all boxes, with a success pulse.\",\n    \"description\": \"The ubiquitous 2FA/verification pattern: separate boxes per digit that auto-advance as you type, handle backspace navigation, accept a pasted full code across all inputs, and animate to a success state when complete.\",\n    \"theme\": \"forms-inputs\",\n    \"categories\": [\"form\", \"input\", \"interaction\"],\n    \"tags\": [\"otp\", \"verification\", \"2fa\", \"code\", \"auto-advance\", \"paste\", \"2026-trend\"],\n    \"tech\": [\"css\", \"js\"],\n    \"era\": \"2020s\",\n    \"difficulty\": \"intermediate\",\n    \"dependencies\": [],\n    \"browser_support\": \"All modern browsers.\",\n    \"performance_notes\": \"A few input event handlers; negligible.\",\n    \"accessibility_notes\": \"Real <input>s with inputmode=numeric and autocomplete='one-time-code' (enables OS autofill), labeled as a group; focus-visible rings; success announced via aria-live. Backspace and arrow navigation supported.\",\n    \"customization\": [\n      { \"name\": \"length\", \"description\": \"Number of digits\", \"default\": \"6\" },\n      { \"name\": \"--accent / --ok\", \"description\": \"Focus + success colors\", \"default\": \"violet / green\" }\n    ],\n    \"variations\": [\"4-digit PIN\", \"Alphanumeric codes\", \"Auto-submit on completion\"],\n    \"related\": [\"floating-label-input\", \"animated-checkbox\"],\n    \"ai_usage\": \"Use for 2FA, email/phone verification, and PIN entry. Render N inputs with inputmode='numeric', maxlength=1, and autocomplete='one-time-code' on the first (for OS autofill). On input, move focus to the next; on Backspace when empty, focus the previous; on paste, distribute digits across boxes. Wrap in a labeled group, keep focus-visible, and announce completion via an aria-live region.\"\n  }\n  </script>\n  <style>\n    :root{--accent:#7c5cff;--ok:#22c55e;--bg:#11131b;--line:#2a3040;}\n    html,body{height:100%;margin:0}\n    body{display:grid;place-items:center;background:#0b0d12;color:#e8ecf6;font-family:system-ui,sans-serif;text-align:center}\n    fieldset{border:none;margin:0;padding:0}\n    legend{font-size:1.2rem;font-weight:700;margin-bottom:.3rem}\n    .sub{color:#8b93a7;margin-bottom:1.2rem;font-size:.95rem}\n    .otp{display:flex;gap:.6rem;justify-content:center}\n    .otp input{width:54px;height:64px;text-align:center;font-size:1.6rem;font-weight:700;color:#fff;background:var(--bg);\n      border:2px solid var(--line);border-radius:12px;outline:none;transition:border-color .15s,transform .15s,box-shadow .15s}\n    .otp input:focus{border-color:var(--accent);box-shadow:0 0 0 4px rgba(124,92,255,.25)}\n    .otp input.filled{border-color:var(--accent)}\n    .otp.done input{border-color:var(--ok);animation:pop .3s ease}\n    @keyframes pop{50%{transform:translateY(-6px)}}\n    .status{margin-top:1rem;min-height:1.3em;font-weight:600;color:var(--ok)}\n    @media(prefers-reduced-motion:reduce){.otp input{transition:none}.otp.done input{animation:none}}\n  </style>\n</head>\n<body>\n  <form id=\"form\">\n    <fieldset>\n      <legend>Enter verification code</legend>\n      <p class=\"sub\">We sent a 6-digit code to your email.</p>\n      <div class=\"otp\" id=\"otp\" role=\"group\" aria-label=\"6-digit verification code\">\n        <input inputmode=\"numeric\" maxlength=\"1\" autocomplete=\"one-time-code\" aria-label=\"Digit 1\" />\n        <input inputmode=\"numeric\" maxlength=\"1\" aria-label=\"Digit 2\" />\n        <input inputmode=\"numeric\" maxlength=\"1\" aria-label=\"Digit 3\" />\n        <input inputmode=\"numeric\" maxlength=\"1\" aria-label=\"Digit 4\" />\n        <input inputmode=\"numeric\" maxlength=\"1\" aria-label=\"Digit 5\" />\n        <input inputmode=\"numeric\" maxlength=\"1\" aria-label=\"Digit 6\" />\n      </div>\n      <p class=\"status\" id=\"status\" role=\"status\" aria-live=\"polite\"></p>\n    </fieldset>\n  </form>\n  <script>\n    var wrap=document.getElementById('otp'), inputs=[].slice.call(wrap.querySelectorAll('input')), status=document.getElementById('status');\n    function check(){\n      var code=inputs.map(function(i){return i.value;}).join('');\n      inputs.forEach(function(i){i.classList.toggle('filled',!!i.value);});\n      if(code.length===inputs.length && /^\\d+$/.test(code)){\n        wrap.classList.add('done'); status.textContent='✓ Verified — code '+code;\n      } else { wrap.classList.remove('done'); status.textContent=''; }\n    }\n    inputs.forEach(function(inp,idx){\n      inp.addEventListener('input',function(e){\n        this.value=this.value.replace(/\\D/g,'').slice(0,1);\n        if(this.value && idx<inputs.length-1) inputs[idx+1].focus();\n        check();\n      });\n      inp.addEventListener('keydown',function(e){\n        if(e.key==='Backspace' && !this.value && idx>0){inputs[idx-1].focus();}\n        if(e.key==='ArrowLeft' && idx>0){inputs[idx-1].focus();}\n        if(e.key==='ArrowRight' && idx<inputs.length-1){inputs[idx+1].focus();}\n      });\n      inp.addEventListener('paste',function(e){\n        e.preventDefault();\n        var d=(e.clipboardData||window.clipboardData).getData('text').replace(/\\D/g,'').split('');\n        for(var k=0;k<inputs.length;k++){ inputs[k].value=d[k]||''; }\n        inputs[Math.min(d.length,inputs.length-1)].focus();\n        check();\n      });\n    });\n  </script>\n</body>\n</html>\n"
}
