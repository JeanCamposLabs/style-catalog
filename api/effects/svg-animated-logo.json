{
  "id": "svg-animated-logo",
  "title": "SVG Animated Logo Reveal",
  "summary": "A logo mark that draws its outline (stroke), then fills with color — the classic brand intro / splash reveal.",
  "description": "Combines two SVG techniques into a brand moment: first the logo's paths stroke themselves on via stroke-dashoffset, then the fill fades in and the wordmark slides up. Ideal as a page/app splash or header entrance.",
