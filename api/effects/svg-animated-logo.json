  "difficulty": "intermediate",
  "dependencies": [],
  "browser_support": "All modern browsers.",
  "performance_notes": "stroke-dashoffset draw + an opacity fill fade + a small translate on the wordmark. One-shot, then static.",
  "accessibility_notes": "Give the SVG role='img' and a <title> (the brand name) so it has an accessible name. Under prefers-reduced-motion, show the final filled logo immediately.",
