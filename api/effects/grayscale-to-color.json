  "ai_usage": "Use for logo walls, partner grids, and team photos to create focus on hover. Rest: filter: grayscale(var(--rest)); hover/focus-within: grayscale(0) + optional scale. Trigger on :focus-within too for keyboard users. For a 'spotlight' grid, mute the whole container and only un-mute the hovered child. Replace the gradient placeholders with real <img> + alt text.",
  "path": "effects/hover-interactions/grayscale-to-color.html",
  "source": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>Grayscale to Color on Hover</title>\n  <script type=\"application/json\" id=\"effect-meta\">\n  {\n    \"id\": \"grayscale-to-color\",\n    \"title\": \"Grayscale to Color on Hover\",\n    \"summary\": \"A muted grayscale image blooms into full color on hover — great for logo walls and team grids.\",\n    \"description\": \"Applies filter: grayscale(1) at rest and transitions to grayscale(0) (optionally with a slight scale) on hover/focus, drawing attention to the hovered item.\",\n    \"theme\": \"hover-interactions\",\n    \"categories\": [\"hover\", \"image\", \"filter\"],\n    \"tags\": [\"grayscale\", \"filter\", \"hover\", \"logo-wall\", \"team\", \"desaturate\"],\n    \"tech\": [\"css\"],\n    \"era\": \"timeless\",\n    \"difficulty\": \"beginner\",\n    \"dependencies\": [],\n    \"browser_support\": \"All browsers (filter).\",\n    \"performance_notes\": \"Animating filter is GPU-accelerated in modern browsers; fine for a grid of moderate size.\",\n    \"accessibility_notes\": \"Also trigger on :focus-within so keyboard users get the effect. Color must not be the only way information is conveyed.\",\n    \"customization\": [\n      { \"name\": \"--rest\", \"description\": \"Resting grayscale amount\", \"default\": \"100%\" }\n    ],\n    \"variations\": [\"Partial desaturation (60%) at rest\", \"Sepia/blur at rest instead\", \"Whole grid muted except the hovered item\"],\n    \"related\": [\"image-zoom-reveal\", \"duotone-image\"],\n    \"ai_usage\": \"Use for logo walls, partner grids, and team photos to create focus on hover. Rest: filter: grayscale(var(--rest)); hover/focus-within: grayscale(0) + optional scale. Trigger on :focus-within too for keyboard users. For a 'spotlight' grid, mute the whole container and only un-mute the hovered child. Replace the gradient placeholders with real <img> + alt text.\"\n  }\n  </script>\n  <style>\n    :root { --rest: 100%; }\n    html, body { height: 100%; margin: 0; }\n    body { display: grid; place-items: center; background: #0b0d12; font-family: system-ui, sans-serif; }\n    .grid { display: grid; grid-template-columns: repeat(3, 80px); gap: 1rem; }\n    .item {\n      width: 80px; height: 80px; border-radius: 14px; filter: grayscale(var(--rest)); opacity: .75;\n      transition: filter .35s ease, transform .35s ease, opacity .35s ease;\n    }\n    .item:hover, .item:focus-visible { filter: grayscale(0); transform: scale(1.08); opacity: 1; outline: none; }\n    .a { background: linear-gradient(135deg,#7c5cff,#5b3ee0); }\n    .b { background: linear-gradient(135deg,#2dd4bf,#0ea5a5); }\n    .c { background: linear-gradient(135deg,#f0abfc,#c026d3); }\n    .d { background: linear-gradient(135deg,#fb7185,#e11d48); }\n    .e { background: linear-gradient(135deg,#38bdf8,#0369a1); }\n    .f { background: linear-gradient(135deg,#fbbf24,#d97706); }\n    @media (prefers-reduced-motion: reduce) { .item { transition: none; } }\n  </style>\n</head>\n<body>\n  <div class=\"grid\">\n    <div class=\"item a\" tabindex=\"0\"></div><div class=\"item b\" tabindex=\"0\"></div><div class=\"item c\" tabindex=\"0\"></div>\n    <div class=\"item d\" tabindex=\"0\"></div><div class=\"item e\" tabindex=\"0\"></div><div class=\"item f\" tabindex=\"0\"></div>\n  </div>\n</body>\n</html>\n"
}
