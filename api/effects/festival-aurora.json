  "source": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n<title>Music Festival — Aurora</title>\n<script type=\"application/json\" id=\"effect-meta\">\n{\n  \"id\": \"festival-aurora\",\n  \"title\": \"Music Festival — Aurora\",\n  \"summary\": \"A premium, self-contained music festival landing page in the Aurora style, with catalog effects (animated gradient, glass nav, scroll-reveal, card-lift, scroll-progress, gradient text) baked in.\",\n  \"description\": \"Full-page Music Festival template — “Three days of sound & sun.”. Sticky glass nav, animated hero, 6 sections, and a footer, all in one file. Recolor via the :root tokens; replace the marked content. Part of a generated family spanning 12 palettes.\",\n  \"theme\": \"website-templates\",\n  \"categories\": [\n    \"template\",\n    \"events\"\n  ],\n  \"tags\": [\n    \"template\",\n    \"full-page\",\n    \"festival\",\n    \"events\",\n    \"aurora\",\n    \"responsive\",\n    \"effects\"\n  ],\n  \"tech\": [\n    \"html\",\n    \"css\",\n    \"js\"\n  ],\n  \"era\": \"2020s\",\n  \"difficulty\": \"intermediate\",\n  \"dependencies\": [],\n  \"browser_support\": \"All modern browsers.\",\n  \"performance_notes\": \"Pure HTML/CSS + a few lines of vanilla JS (scroll-progress, IntersectionObserver reveals). No images or libraries.\",\n  \"accessibility_notes\": \"Semantic landmarks, real headings/links/forms, focus-visible rings, and a prefers-reduced-motion guard that disables animation and reveals.\",\n  \"customization\": [\n    {\n      \"name\": \":root tokens\",\n      \"description\": \"Palette colors, radius, fonts\",\n      \"default\": \"Aurora palette\"\n    },\n    {\n      \"name\": \"content regions\",\n      \"description\": \"Brand, headline, features, prices, copy\",\n      \"default\": \"edit markup\"\n    }\n  ],\n  \"variations\": [\n    \"Same template in other palettes (midnight, aurora, glass, neon, forest, ocean, paper, mono, pastel, sunset, corporate, brutalist)\",\n    \"Reorder or drop sections\",\n    \"Swap gradient placeholders for real images\"\n  ],\n  \"related\": [\n    \"animated-gradient\",\n    \"glass-navbar\",\n    \"card-lift\",\n    \"reveal-on-scroll\",\n    \"scroll-progress-bar\",\n    \"gradient-text\"\n  ],\n  \"ai_usage\": \"Use as a ready-to-ship Music Festival page. Copy the whole file; reskin by editing the :root custom properties (colors/radius/font) and replacing the content in each <section>. Sections are independent — reorder or delete freely. It composes catalog effects inline (animated gradient hero, glassmorphic sticky nav, scroll-triggered reveals, card hover-lift, a scroll-progress bar, and gradient text) so you get a premium feel with zero dependencies. Replace the gradient placeholder blocks with real <img> (add alt text). Responsive and reduced-motion safe out of the box.\"\n}\n</script>\n<style>\n*{box-sizing:border-box}html{scroll-behavior:smooth}\nbody{margin:0;background:#0a0a14;color:#f0eefb;font-family:system-ui,sans-serif;line-height:1.6;-webkit-font-smoothing:antialiased}\nimg{max-width:100%}a{color:inherit;text-decoration:none}\n.wrap{max-width:1140px;margin:0 auto;padding:0 1.3rem}\nh1,h2,h3{line-height:1.1;margin:0 0 .5rem}\nh1{font-size:clamp(2.2rem,6vw,4rem);font-weight:800}\nh2{font-size:clamp(1.7rem,3.6vw,2.6rem);font-weight:800}\np{margin:0 0 1rem}\n.grad{background:linear-gradient(120deg,#ff5da2,#22d3ee);-webkit-background-clip:text;background-clip:text;color:transparent}\n.eyebrow{font-size:.78rem;letter-spacing:.16em;text-transform:uppercase;font-weight:700;color:#22d3ee}\n.muted{color:#9a93b5}\n.prog{position:fixed;top:0;left:0;height:3px;width:0;background:linear-gradient(120deg,#ff5da2,#22d3ee);z-index:99}\nnav.bar{position:sticky;top:0;z-index:40;border-bottom:1px solid #262640;background:#0a0a14cc;backdrop-filter:blur(12px)}\nnav.bar .wrap{display:flex;align-items:center;justify-content:space-between;height:64px}\n.brand{font-weight:900;font-size:1.15rem;display:flex;align-items:center;gap:.5rem}\n.brand .dot{width:22px;height:22px;border-radius:7px;background:linear-gradient(120deg,#ff5da2,#22d3ee);display:inline-block}\n.navlinks{display:flex;gap:1.5rem;align-items:center}\n.navlinks a{color:#9a93b5;font-size:.92rem;font-weight:600}\n.navlinks a:hover{color:#f0eefb}\n.btn{display:inline-block;cursor:pointer;font-weight:700;border-radius:18px;padding:.78rem 1.5rem;border:1px solid transparent;background:linear-gradient(120deg,#ff5da2,#22d3ee);color:#fff;transition:transform .12s,box-shadow .12s,filter .12s;}\n.btn:hover{transform:translateY(-2px);filter:brightness(1.06);box-shadow:0 10px 24px rgba(0,0,0,.5)}\n.btn.ghost{background:transparent;color:#f0eefb;border:1px solid #262640}\n.btn:focus-visible,.navlinks a:focus-visible{outline:3px solid #22d3ee;outline-offset:2px}\n.sec{padding:clamp(3rem,7vw,5.5rem) 0}\n.sec.tint{background:#181828}\n.center{text-align:center}.lead{max-width:60ch;margin-inline:auto;font-size:1.12rem}\n.grid{display:grid;gap:1.2rem}\n.card{background:#12121f;border:1px solid #262640;border-radius:18px;padding:1.4rem;box-shadow:0 12px 40px rgba(0,0,0,.45);transition:transform .18s,box-shadow .18s}\n.card.lift:hover{transform:translateY(-7px)}\n.ph{border-radius:18px;aspect-ratio:16/10;display:block}\n.tag{display:inline-block;font-size:.75rem;padding:.2rem .6rem;border-radius:999px;background:#181828;color:#9a93b5;border:1px solid #262640}\n.reveal{opacity:0;transform:translateY(22px);transition:opacity .7s ease,transform .7s cubic-bezier(.2,.8,.2,1)}\n.reveal.in{opacity:1;transform:none}\n.kpi{font-size:clamp(2rem,5vw,3.2rem);font-weight:900;}\ndetails{border-top:1px solid #262640;padding:1rem 0}details summary{cursor:pointer;font-weight:700;list-style:none;display:flex;justify-content:space-between}\ndetails summary::-webkit-details-marker{display:none}details[open] summary{color:#22d3ee}\nfooter.ft{border-top:1px solid #262640;background:#181828}\nfooter.ft .wrap{padding:2.4rem 1.3rem}\n.fcols{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:1.5rem}\n.fcols a{display:block;color:#9a93b5;padding:.2rem 0;font-size:.9rem}\n.hero-bg{position:relative;overflow:hidden}\n.hero-bg::before{content:\"\";position:absolute;inset:-30% -10% auto;height:70vmax;background:radial-gradient(closest-side,#ff5da240,transparent 70%),radial-gradient(closest-side,#22d3ee33,transparent 70%);background-position:30% 0,80% 10%;background-repeat:no-repeat;filter:blur(10px);animation:float 16s ease-in-out infinite;pointer-events:none}\n@keyframes float{50%{transform:translateY(40px) scale(1.05)}}\n@media(max-width:820px){.navlinks{display:none}.fcols{grid-template-columns:1fr 1fr}}\n@media(prefers-reduced-motion:reduce){*{animation:none!important;scroll-behavior:auto}.reveal{opacity:1;transform:none;transition:none}.hero-bg::before{animation:none}}\n</style>\n</head>\n<body>\n<div class=\"prog\"></div>\n<nav class=\"bar\"><div class=\"wrap\">\n    <a class=\"brand\" href=\"#\"><span class=\"dot\"></span>Sundown</a>\n    <div class=\"navlinks\"><a href=\"#\">Lineup</a><a href=\"#\">Tickets</a><a href=\"#\">Info</a><a href=\"#\">Travel</a><a class=\"btn\" href=\"#\">Buy passes</a></div>\n  </div></nav>\n<header class=\"sec hero-bg\"><div class=\"wrap center\">\n    <p class=\"eyebrow reveal\">Aug 8–10 · Riverside Park</p>\n    <h1 class=\"reveal\">Three days of <span class=\"grad\">sound & sun</span>.</h1>\n    <p class=\"lead muted reveal\">Forty artists across five stages. Camp out, dance hard, make memories.</p>\n    <div class=\"reveal\" style=\"display:flex;gap:.8rem;justify-content:center;flex-wrap:wrap;margin-top:1.4rem\">\n      <a class=\"btn\" href=\"#\">Buy passes</a><a class=\"btn ghost\" href=\"#\">Lineup</a>\n    </div>\n    <div class=\"ph reveal\" style=\"max-width:920px;margin:2.6rem auto 0;aspect-ratio:16/8;background:linear-gradient(135deg,#ff5da2,#22d3ee)\"></div>\n  </div></header>\n<section class=\"sec\"><div class=\"wrap\">\n    <div class=\"center reveal\"><p class=\"eyebrow\">Gallery</p><h2>Selected work</h2></div>\n    <div class=\"grid reveal\" style=\"grid-template-columns:repeat(auto-fit,minmax(220px,1fr));margin-top:2rem\">\n      <div class=\"ph lift\" style=\"aspect-ratio:1;background:linear-gradient(135deg,#ff5da2,#22d3ee)\"></div><div class=\"ph lift\" style=\"aspect-ratio:1;background:linear-gradient(135deg,#22d3ee,#ff5da2)\"></div><div class=\"ph lift\" style=\"aspect-ratio:1;background:linear-gradient(135deg,#a78bfa,#22d3ee)\"></div><div class=\"ph lift\" style=\"aspect-ratio:1;background:linear-gradient(135deg,#fb7185,#fbbf24)\"></div><div class=\"ph lift\" style=\"aspect-ratio:1;background:linear-gradient(135deg,#34d399,#0ea5e9)\"></div><div class=\"ph lift\" style=\"aspect-ratio:1;background:linear-gradient(135deg,#f472b6,#a78bfa)\"></div>\n    </div></div></section>\n<section class=\"sec tint\"><div class=\"wrap grid reveal\" style=\"grid-template-columns:repeat(auto-fit,minmax(160px,1fr));text-align:center\">\n    <div><div class=\"kpi grad\">10k+</div><div class=\"muted\">Customers</div></div><div><div class=\"kpi grad\">99.9%</div><div class=\"muted\">Uptime</div></div><div><div class=\"kpi grad\">4.9/5</div><div class=\"muted\">Rating</div></div><div><div class=\"kpi grad\">120+</div><div class=\"muted\">Countries</div></div>\n  </div></section>\n<section class=\"sec tint\"><div class=\"wrap\">\n    <div class=\"center reveal\"><p class=\"eyebrow\">Pricing</p><h2>Simple, fair pricing</h2></div>\n    <div class=\"grid reveal\" style=\"grid-template-columns:repeat(auto-fit,minmax(240px,1fr));margin-top:2rem;align-items:start\">\n      <div class=\"card\" style=\"\"><h3>Starter</h3><div class=\"kpi\">$0<span class=\"muted\" style=\"font-size:1rem;font-weight:400\">/mo</span></div><ul style=\"list-style:none;padding:0;margin:1rem 0\"><li class=\"muted\" style=\"padding:.3rem 0\">✓ 1 project</li><li class=\"muted\" style=\"padding:.3rem 0\">✓ Community support</li></ul><a class=\"btn ghost\" href=\"#\" style=\"width:100%;text-align:center\">Choose</a></div><div class=\"card lift\" style=\"border:2px solid #ff5da2;\"><h3>Pro</h3><div class=\"kpi\">$29<span class=\"muted\" style=\"font-size:1rem;font-weight:400\">/mo</span></div><ul style=\"list-style:none;padding:0;margin:1rem 0\"><li class=\"muted\" style=\"padding:.3rem 0\">✓ Unlimited projects</li><li class=\"muted\" style=\"padding:.3rem 0\">✓ Priority support</li><li class=\"muted\" style=\"padding:.3rem 0\">✓ Advanced tools</li></ul><a class=\"btn\" href=\"#\" style=\"width:100%;text-align:center\">Choose</a></div><div class=\"card\" style=\"\"><h3>Scale</h3><div class=\"kpi\">$99<span class=\"muted\" style=\"font-size:1rem;font-weight:400\">/mo</span></div><ul style=\"list-style:none;padding:0;margin:1rem 0\"><li class=\"muted\" style=\"padding:.3rem 0\">✓ Everything in Pro</li><li class=\"muted\" style=\"padding:.3rem 0\">✓ SSO & SAML</li><li class=\"muted\" style=\"padding:.3rem 0\">✓ Dedicated SLA</li></ul><a class=\"btn ghost\" href=\"#\" style=\"width:100%;text-align:center\">Choose</a></div>\n    </div></div></section>\n<section class=\"sec\"><div class=\"wrap\" style=\"max-width:760px\">\n    <div class=\"center reveal\"><p class=\"eyebrow\">FAQ</p><h2>Questions, answered</h2></div>\n    <div class=\"reveal\" style=\"margin-top:1.6rem\">\n      <details><summary>Is there a free trial?<span>+</span></summary><p class=\"muted\" style=\"margin-top:.7rem\">Yes — start free, no card required.</p></details><details><summary>Can I cancel anytime?<span>+</span></summary><p class=\"muted\" style=\"margin-top:.7rem\">Absolutely, in one click.</p></details><details><summary>Do you offer support?<span>+</span></summary><p class=\"muted\" style=\"margin-top:.7rem\">Friendly humans, around the clock.</p></details><details><summary>Is my data safe?<span>+</span></summary><p class=\"muted\" style=\"margin-top:.7rem\">Encrypted in transit and at rest.</p></details>\n    </div></div></section>\n<section class=\"sec\"><div class=\"wrap\"><div class=\"card reveal center hero-bg\" style=\"padding:3rem 1.5rem;background:linear-gradient(135deg,#ff5da21f,#22d3ee1f)\">\n    <h2>Ready to start?</h2><p class=\"lead muted\">Join thousands already on board. It only takes a minute.</p>\n    <a class=\"btn\" href=\"#\" style=\"margin-top:.6rem\">Buy passes</a>\n  </div></div></section>\n<footer class=\"ft\"><div class=\"wrap\"><div class=\"fcols\">\n    <div><div class=\"brand\"><span class=\"dot\"></span>Sundown</div><p class=\"muted\" style=\"margin-top:.6rem;max-width:30ch\">Forty artists across five stages. Camp out, dance hard, make memories.</p></div>\n    <div><strong>Product</strong><a href=\"#\">Features</a><a href=\"#\">Pricing</a><a href=\"#\">Changelog</a></div><div><strong>Company</strong><a href=\"#\">About</a><a href=\"#\">Blog</a><a href=\"#\">Careers</a></div><div><strong>Legal</strong><a href=\"#\">Privacy</a><a href=\"#\">Terms</a><a href=\"#\">Status</a></div>\n  </div><p class=\"muted\" style=\"margin-top:1.8rem;font-size:.85rem\">© <span id=\"yr\"></span> Sundown. All rights reserved.</p></div></footer>\n<script>\n(function(){\n  var bar=document.querySelector('.prog');\n  function sp(){if(!bar)return;var h=document.documentElement;var m=h.scrollHeight-h.clientHeight;bar.style.width=(m>0?(h.scrollTop/m*100):0)+'%';}\n  document.addEventListener('scroll',sp,{passive:true});sp();\n  var io=new IntersectionObserver(function(es){es.forEach(function(e){if(e.isIntersecting){e.target.classList.add('in');io.unobserve(e.target);}})},{threshold:.12});\n  document.querySelectorAll('.reveal').forEach(function(el){io.observe(el)});\n  var y=document.getElementById('yr');if(y)y.textContent=new Date().getFullYear();\n})();\n</script>\n</body>\n</html>\n"
}
