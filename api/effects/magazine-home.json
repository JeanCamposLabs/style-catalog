  "source": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Editorial — Magazine Homepage</title>\n<script type=\"application/json\" id=\"effect-meta\">\n{\n  \"id\": \"magazine-home\",\n  \"title\": \"Editorial — Magazine Homepage\",\n  \"summary\": \"A digital magazine front page: a serif masthead, a lead feature, a ruled multi-column story grid, a category rail, and a most-read list.\",\n  \"description\": \"An editorial homepage in the contemporary digital-magazine idiom — a centered serif masthead with a date/issue line, a dominant lead story, an asymmetric grid of articles separated by hairlines, a category rail, and a numbered 'most read' column. Print sensibility, screen layout.\",\n  \"theme\": \"website-templates\",\n  \"categories\": [\"template\", \"blog\", \"editorial\"],\n  \"tags\": [\"magazine\", \"editorial\", \"news\", \"publication\", \"grid\", \"serif\", \"full-page\"],\n  \"tech\": [\"html\", \"css\", \"js\"],\n  \"era\": \"timeless\",\n  \"difficulty\": \"intermediate\",\n  \"dependencies\": [],\n  \"browser_support\": \"All modern browsers (CSS Grid).\",\n  \"performance_notes\": \"Type, hairline rules, and gradient placeholders; one fade-up reveal. No images or libraries.\",\n  \"accessibility_notes\": \"Real article links and heading order, high contrast, focus-visible underlines, reduced-motion safe.\",\n  \"customization\": [\n    { \"name\": \"--ink/--paper/--accent\", \"description\": \"Text, page, kicker color\", \"default\": \"near-black / ivory / red\" },\n    { \"name\": \"grid layout\", \"description\": \"Lead + columns spans\", \"default\": \"asymmetric\" }\n  ],\n  \"variations\": [\"Dark mode magazine\", \"Photo-led cards instead of gradient blocks\", \"Add a newsletter ribbon\"],\n  \"related\": [\"type-scale\", \"hairline-divider\", \"readable-measure\"],\n  \"ai_usage\": \"Use for magazines, news, blogs, and publications. Structure: serif masthead + issue line, one lead feature, a hairline-separated article grid (vary spans for rhythm), a category rail, and a numbered most-read list. Recolor via tokens; keep the red (or your brand) kicker for category tags. Replace headlines, decks, and the gradient image blocks with real photos. Reduced-motion safe.\"\n}\n</script>\n<style>\n  :root{--ink:#161412;--paper:#f7f4ee;--muted:#6f695f;--line:#d9d3c7;--accent:#c2261b;\n    --serif:\"Playfair Display\",\"Georgia\",serif;--sans:\"Inter\",system-ui,sans-serif;}\n  *{box-sizing:border-box}html{scroll-behavior:smooth}\n  body{margin:0;background:var(--paper);color:var(--ink);font-family:var(--sans);line-height:1.5}\n  a{color:inherit;text-decoration:none}\n  .wrap{max-width:1180px;margin:0 auto;padding:0 1.6rem}\n  .top{display:flex;justify-content:space-between;align-items:center;font-size:.78rem;color:var(--muted);padding:.7rem 0;border-bottom:1px solid var(--line);text-transform:uppercase;letter-spacing:.08em}\n  .top a{margin-left:1rem}.top a:hover{color:var(--ink)}\n  .masthead{text-align:center;padding:1.8rem 0 1rem;border-bottom:3px double var(--ink)}\n  .masthead h1{font-family:var(--serif);font-weight:800;font-size:clamp(2.4rem,8vw,5.5rem);letter-spacing:.02em;margin:0}\n  .masthead .issue{font-size:.76rem;color:var(--muted);letter-spacing:.22em;text-transform:uppercase;margin-top:.4rem}\n  .rail{display:flex;gap:1.4rem;justify-content:center;flex-wrap:wrap;padding:.7rem 0;border-bottom:1px solid var(--line);font-size:.84rem;font-weight:600;text-transform:uppercase;letter-spacing:.06em}\n  .rail a:hover{color:var(--accent)}\n  .kick{color:var(--accent);font-weight:700;font-size:.74rem;letter-spacing:.12em;text-transform:uppercase}\n  .lead{display:grid;grid-template-columns:1.5fr 1fr;gap:2.4rem;padding:2.4rem 0;border-bottom:1px solid var(--line)}\n  .lead .img{aspect-ratio:16/10;background:linear-gradient(135deg,#3b3a36,#6b5b4a)}\n  .lead h2{font-family:var(--serif);font-weight:700;font-size:clamp(2rem,4.5vw,3.4rem);line-height:1.05;margin:.6rem 0}\n  .lead p{color:var(--muted);font-size:1.05rem;max-width:42ch}\n  .byline{font-size:.8rem;color:var(--muted);margin-top:.6rem}\n  .grid{display:grid;grid-template-columns:repeat(4,1fr);gap:0;padding:2rem 0}\n  .art{padding:0 1.4rem;border-left:1px solid var(--line)}\n  .art:first-child{padding-left:0;border-left:none}\n  .art .img{aspect-ratio:4/3;margin-bottom:.7rem}\n  .a1{background:linear-gradient(135deg,#c2261b,#e8794f)}.a2{background:linear-gradient(135deg,#274b8f,#5aa0d6)}\n  .a3{background:linear-gradient(135deg,#2f6b4d,#7bbf8a)}.a4{background:linear-gradient(135deg,#6b4a8f,#b48ad6)}\n  .art h3{font-family:var(--serif);font-weight:700;font-size:1.25rem;line-height:1.15;margin:.2rem 0 .3rem}\n  .art p{color:var(--muted);font-size:.9rem;margin:0}\n  .split{display:grid;grid-template-columns:2fr 1fr;gap:2.4rem;border-top:1px solid var(--line);padding:2.4rem 0}\n  .opinion .o{display:grid;grid-template-columns:auto 1fr;gap:1rem;align-items:start;padding:1.2rem 0;border-bottom:1px solid var(--line)}\n  .opinion .o .av{width:54px;height:54px;border-radius:50%;background:linear-gradient(135deg,#888,#444)}\n  .opinion h3{font-family:var(--serif);font-size:1.2rem;margin:0 0 .2rem}.opinion .who{color:var(--muted);font-size:.8rem}\n  .most h4{font-family:var(--sans);text-transform:uppercase;letter-spacing:.1em;font-size:.8rem;color:var(--accent);border-bottom:2px solid var(--ink);padding-bottom:.5rem;margin:0 0 .5rem}\n  .most a{display:grid;grid-template-columns:auto 1fr;gap:.9rem;padding:.9rem 0;border-bottom:1px solid var(--line);align-items:baseline}\n  .most .n{font-family:var(--serif);font-size:1.8rem;color:var(--muted)}\n  .most .t{font-family:var(--serif);font-size:1.05rem;line-height:1.2}\n  .most a:hover .t{color:var(--accent)}\n  footer{border-top:3px double var(--ink);text-align:center;color:var(--muted);padding:2rem 0 3rem;font-size:.85rem}\n  .reveal{opacity:0;transform:translateY(18px);transition:opacity .6s,transform .6s ease}.reveal.in{opacity:1;transform:none}\n  @media(max-width:860px){.lead,.split{grid-template-columns:1fr}.grid{grid-template-columns:1fr 1fr}.art{border-left:none;padding:0}}\n  @media(max-width:520px){.grid{grid-template-columns:1fr}}\n  @media(prefers-reduced-motion:reduce){.reveal{opacity:1;transform:none;transition:none}html{scroll-behavior:auto}}\n</style>\n</head>\n<body>\n  <div class=\"wrap\">\n    <div class=\"top\">\n      <span>Friday, May 30, 2026</span>\n      <span><a href=\"#\">Subscribe</a><a href=\"#\">Sign in</a><a href=\"#\">◷</a></span>\n    </div>\n    <div class=\"masthead\">\n      <h1>The Meridian</h1>\n      <div class=\"issue\">Ideas · Culture · Technology — No. 412</div>\n    </div>\n    <nav class=\"rail\"><a href=\"#\">World</a><a href=\"#\">Business</a><a href=\"#\">Tech</a><a href=\"#\">Culture</a><a href=\"#\">Science</a><a href=\"#\">Opinion</a><a href=\"#\">Style</a></nav>\n\n    <section class=\"lead\">\n      <div>\n        <div class=\"img reveal\" role=\"img\" aria-label=\"Lead story\"></div>\n      </div>\n      <div class=\"reveal\">\n        <span class=\"kick\">The Big Read</span>\n        <h2>The quiet rebuilding of the open web.</h2>\n        <p>A new generation of builders is trading walled gardens for protocols — and quietly rewiring how we publish, own, and connect online.</p>\n        <div class=\"byline\">By Eleanor Pace · 14 min read</div>\n      </div>\n    </section>\n\n    <section class=\"grid\">\n      <article class=\"art reveal\"><div class=\"img a1\" role=\"img\" aria-label=\"\"></div><span class=\"kick\">Business</span><h3>The four-day week, two years on</h3><p>What the data actually shows.</p></article>\n      <article class=\"art reveal\"><div class=\"img a2\" role=\"img\" aria-label=\"\"></div><span class=\"kick\">Science</span><h3>Mapping the deep ocean's last blanks</h3><p>The final 20%.</p></article>\n      <article class=\"art reveal\"><div class=\"img a3\" role=\"img\" aria-label=\"\"></div><span class=\"kick\">Culture</span><h3>Why everyone's reading slowly again</h3><p>The case for the long form.</p></article>\n      <article class=\"art reveal\"><div class=\"img a4\" role=\"img\" aria-label=\"\"></div><span class=\"kick\">Style</span><h3>The return of the unbranded</h3><p>Logos are out. Again.</p></article>\n    </section>\n\n    <section class=\"split\">\n      <div class=\"opinion\">\n        <h4 class=\"kick\" style=\"border-bottom:2px solid var(--ink);padding-bottom:.5rem;margin:0 0 .5rem\">Opinion</h4>\n        <a class=\"o\" href=\"#\"><div class=\"av\"></div><div><h3>We optimized away serendipity. Let's get it back.</h3><div class=\"who\">Marcus Hale · Columnist</div></div></a>\n        <a class=\"o\" href=\"#\"><div class=\"av\"></div><div><h3>The city is a feature, not a bug.</h3><div class=\"who\">Dana Ortiz · Guest essay</div></div></a>\n        <a class=\"o\" href=\"#\"><div class=\"av\"></div><div><h3>In defense of doing one thing.</h3><div class=\"who\">P. K. Lin · Columnist</div></div></a>\n      </div>\n      <aside class=\"most\">\n        <h4>Most read</h4>\n        <a href=\"#\"><span class=\"n\">1</span><span class=\"t\">The startup that runs on four employees and a lot of agents</span></a>\n        <a href=\"#\"><span class=\"n\">2</span><span class=\"t\">A field guide to quitting your phone</span></a>\n        <a href=\"#\"><span class=\"n\">3</span><span class=\"t\">The new typography of train stations</span></a>\n        <a href=\"#\"><span class=\"n\">4</span><span class=\"t\">How a small town saved its high street</span></a>\n        <a href=\"#\"><span class=\"n\">5</span><span class=\"t\">The comeback of the personal homepage</span></a>\n      </aside>\n    </section>\n  </div>\n\n  <footer class=\"wrap\">© <span id=\"yr\"></span> The Meridian · Reader-supported journalism since 1991.</footer>\n  <script>\n    document.getElementById('yr').textContent=new Date().getFullYear();\n    var io=new IntersectionObserver(function(es){es.forEach(function(e){if(e.isIntersecting){e.target.classList.add('in');io.unobserve(e.target)}})},{threshold:.1});\n    document.querySelectorAll('.reveal').forEach(function(el){io.observe(el)});\n  </script>\n</body>\n</html>\n"
