  "source": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>Flat Long Shadow</title>\n  <script type=\"application/json\" id=\"effect-meta\">\n  {\n    \"id\": \"long-shadow\",\n    \"title\": \"Flat Long Shadow\",\n    \"summary\": \"The flat-design 45° long shadow, built from many stacked text-shadows.\",\n    \"description\": \"Stacks dozens of 1px-incremented text-shadows in a darker shade to draw a solid diagonal long shadow — the iconic flat 2.0 / long-shadow style from the mid-2010s.\",\n    \"theme\": \"borders-shadows\",\n    \"categories\": [\"shadow\", \"flat-design\"],\n    \"tags\": [\"long-shadow\", \"flat\", \"flat-2.0\", \"diagonal\", \"retro\", \"text-shadow\"],\n    \"tech\": [\"css\"],\n    \"era\": \"2010s\",\n    \"difficulty\": \"intermediate\",\n    \"dependencies\": [],\n    \"browser_support\": \"All browsers.\",\n    \"performance_notes\": \"Many shadow layers cost a bit of paint; fine for a heading/icon, not body text. Often generated by a preprocessor loop.\",\n    \"accessibility_notes\": \"Decorative; ensure the base text contrast holds on its own.\",\n    \"customization\": [\n      { \"name\": \"--shadow\", \"description\": \"Long-shadow color\", \"default\": \"#3a2d8a\" },\n      { \"name\": \"length\", \"description\": \"Number of stacked shadows\", \"default\": \"~30\" }\n    ],\n    \"variations\": [\"Apply to box-shadow on a shape instead of text\", \"Fade the shadow to transparent at the end\", \"Use a Sass/PostCSS loop to generate the stack\"],\n    \"related\": [\"glow-shadow\"],\n    \"ai_usage\": \"Use for retro flat-design headings, logos, and icons. The shadow is a comma-separated list of text-shadows at 1px,2px,3px… offsets in a darker hue. Generate the long list with a loop (Sass @for, PostCSS, or build-time JS) rather than hand-typing. Keep to large display text; avoid on paragraphs for performance.\"\n  }\n  </script>\n  <style>\n    html, body { height: 100%; margin: 0; }\n    body { display: grid; place-items: center; background: #f5f3ff; font-family: system-ui, sans-serif; }\n    .long-shadow {\n      font-size: 5rem; font-weight: 900; color: #7c5cff; letter-spacing: -.02em;\n      text-shadow:\n        1px 1px #6a4fe0, 2px 2px #6a4fe0, 3px 3px #5f47cf, 4px 4px #5f47cf,\n        5px 5px #543fbe, 6px 6px #543fbe, 7px 7px #4a37ad, 8px 8px #4a37ad,\n        9px 9px #402f9c, 10px 10px #402f9c, 11px 11px #36278b, 12px 12px #36277b,\n        13px 13px #2f226e, 14px 14px #2f226e, 15px 15px #281d61, 16px 16px #281d61,\n        17px 17px #221854, 18px 18px #221854, 19px 19px #1b1447, 20px 20px #1b1447;\n    }\n  </style>\n</head>\n<body>\n  <div class=\"long-shadow\">FLAT</div>\n</body>\n</html>\n"
}
