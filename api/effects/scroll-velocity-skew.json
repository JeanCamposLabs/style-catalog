{
  "id": "scroll-velocity-skew",
  "title": "Scroll Velocity Skew",
  "summary": "Content skews and squashes in proportion to scroll speed, then springs back to rest — a fluid, physical scroll feel.",
  "description": "Tracks scroll velocity each frame and maps it to a skewY (and slight scale) on the content, which eases back to zero when you stop. Fast flicks bend the page; slow scrolls barely move. A signature 'smooth scroll' flourish on award-style sites.",
  "theme": "scroll-effects",
