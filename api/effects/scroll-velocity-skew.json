  "difficulty": "intermediate",
  "dependencies": [],
  "browser_support": "All modern browsers.",
  "performance_notes": "A single requestAnimationFrame loop computing velocity and writing one transform. transform-only — GPU-friendly. Loop is cheap and self-limiting.",
  "accessibility_notes": "Purely decorative motion; content remains fully readable and in order. Disabled entirely under prefers-reduced-motion. Clamp max skew so text never becomes unreadable.",
