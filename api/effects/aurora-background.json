  "ai_usage": "Use as a calm, premium hero/section background on dark UIs. Place the .aurora container behind content (position relative, content with higher z-index). Each blob is an absolutely-positioned blurred radial-gradient; animate their transform (translate) on long, offset loops. Keep blob count low for performance and pick 2-3 analogous-but-distinct colors.",
  "path": "effects/backgrounds/aurora-background.html",
  "source": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>Aurora Background</title>\n  <script type=\"application/json\" id=\"effect-meta\">\n  {\n    \"id\": \"aurora-background\",\n    \"title\": \"Aurora Background\",\n    \"summary\": \"Soft, blurred color blobs drift like northern lights behind your content.\",\n    \"description\": \"Several large radial-gradient blobs are blurred heavily and animated on independent paths over a dark base, creating a calm aurora/northern-lights ambience popular in modern landing pages.\",\n    \"theme\": \"backgrounds\",\n    \"categories\": [\"background\", \"gradient\", \"ambient\"],\n    \"tags\": [\"aurora\", \"blur\", \"blobs\", \"northern-lights\", \"ambient\", \"dark\"],\n    \"tech\": [\"css\"],\n    \"era\": \"2020s\",\n    \"difficulty\": \"intermediate\",\n    \"dependencies\": [],\n    \"browser_support\": \"All modern browsers (filter: blur widely supported).\",\n    \"performance_notes\": \"Large blur radii are GPU-intensive; limit to 2-3 blobs and avoid animating blur itself (animate transform instead).\",\n    \"accessibility_notes\": \"Decorative; keep content on a contrasted surface. Motion stops under prefers-reduced-motion.\",\n    \"customization\": [\n      { \"name\": \"--c1 / --c2 / --c3\", \"description\": \"Aurora blob colors\", \"default\": \"#7c5cff / #2dd4bf / #f0abfc\" },\n      { \"name\": \"blur amount\", \"description\": \"Softness of the blobs\", \"default\": \"70px\" }\n    ],\n    \"variations\": [\"Tighter, brighter blobs for a nebula\", \"Light-mode pastel version\", \"Add grain overlay for film texture\"],\n    \"related\": [\"mesh-gradient\", \"animated-gradient\"],\n    \"ai_usage\": \"Use as a calm, premium hero/section background on dark UIs. Place the .aurora container behind content (position relative, content with higher z-index). Each blob is an absolutely-positioned blurred radial-gradient; animate their transform (translate) on long, offset loops. Keep blob count low for performance and pick 2-3 analogous-but-distinct colors.\"\n  }\n  </script>\n  <style>\n    html, body { height: 100%; margin: 0; }\n    .aurora { position: relative; height: 100vh; overflow: hidden; background: #06060c; }\n    .aurora__blob { position: absolute; width: 50vmax; height: 50vmax; border-radius: 50%; filter: blur(70px); opacity: .55; mix-blend-mode: screen; }\n    .b1 { background: radial-gradient(circle, #7c5cff, transparent 60%); top: -10%; left: -5%; animation: drift1 14s ease-in-out infinite; }\n    .b2 { background: radial-gradient(circle, #2dd4bf, transparent 60%); bottom: -15%; right: -5%; animation: drift2 18s ease-in-out infinite; }\n    .b3 { background: radial-gradient(circle, #f0abfc, transparent 60%); top: 30%; left: 40%; animation: drift3 22s ease-in-out infinite; }\n    @keyframes drift1 { 50% { transform: translate(20vw, 15vh) scale(1.2); } }\n    @keyframes drift2 { 50% { transform: translate(-15vw, -10vh) scale(1.1); } }\n    @keyframes drift3 { 50% { transform: translate(-20vw, 12vh) scale(1.3); } }\n    @media (prefers-reduced-motion: reduce) { .aurora__blob { animation: none; } }\n  </style>\n</head>\n<body>\n  <div class=\"aurora\">\n    <div class=\"aurora__blob b1\"></div>\n    <div class=\"aurora__blob b2\"></div>\n    <div class=\"aurora__blob b3\"></div>\n  </div>\n</body>\n</html>\n"
}
