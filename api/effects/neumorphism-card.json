{
  "id": "neumorphism-card",
  "title": "Neumorphism Card",
  "summary": "A soft, extruded 'soft UI' surface made from twin light and dark shadows.",
  "description": "Uses two box-shadows — a light one top-left and a dark one bottom-right, both the same hue as the background — so elements look pressed out of (or into) the surface. Includes a pressed (inset) variant.",
