  "era": "2020s",
  "difficulty": "intermediate",
  "dependencies": [],
  "browser_support": "All browsers.",
  "performance_notes": "Static dual shadows; trivial. The :active inset swap is cheap.",
  "accessibility_notes": "Notorious for poor contrast — the trend's biggest weakness. Ensure text and interactive states have sufficient contrast; don't rely on shadow alone to convey affordance.",
