  "source": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n<title>Wedding — Paper</title>\n<script type=\"application/json\" id=\"effect-meta\">\n{\n  \"id\": \"wedding-paper\",\n  \"title\": \"Wedding — Paper\",\n  \"summary\": \"A premium, self-contained wedding landing page in the Paper style, with catalog effects (animated gradient, glass nav, scroll-reveal, card-lift, scroll-progress, gradient text) baked in.\",\n  \"description\": \"Full-page Wedding template — “Mia & Sam”. Sticky glass nav, animated hero, 5 sections, and a footer, all in one file. Recolor via the :root tokens; replace the marked content. Part of a generated family spanning 12 palettes.\",\n  \"theme\": \"website-templates\",\n  \"categories\": [\n    \"template\",\n    \"events\"\n  ],\n  \"tags\": [\n    \"template\",\n    \"full-page\",\n    \"wedding\",\n    \"events\",\n    \"paper\",\n    \"responsive\",\n    \"effects\"\n  ],\n  \"tech\": [\n    \"html\",\n    \"css\",\n    \"js\"\n  ],\n  \"era\": \"2020s\",\n  \"difficulty\": \"intermediate\",\n  \"dependencies\": [],\n  \"browser_support\": \"All modern browsers.\",\n  \"performance_notes\": \"Pure HTML/CSS + a few lines of vanilla JS (scroll-progress, IntersectionObserver reveals). No images or libraries.\",\n  \"accessibility_notes\": \"Semantic landmarks, real headings/links/forms, focus-visible rings, and a prefers-reduced-motion guard that disables animation and reveals.\",\n  \"customization\": [\n    {\n      \"name\": \":root tokens\",\n      \"description\": \"Palette colors, radius, fonts\",\n      \"default\": \"Paper palette\"\n    },\n    {\n      \"name\": \"content regions\",\n      \"description\": \"Brand, headline, features, prices, copy\",\n      \"default\": \"edit markup\"\n    }\n  ],\n  \"variations\": [\n    \"Same template in other palettes (midnight, aurora, glass, neon, forest, ocean, paper, mono, pastel, sunset, corporate, brutalist)\",\n    \"Reorder or drop sections\",\n    \"Swap gradient placeholders for real images\"\n  ],\n  \"related\": [\n    \"animated-gradient\",\n    \"glass-navbar\",\n    \"card-lift\",\n    \"reveal-on-scroll\",\n    \"scroll-progress-bar\",\n    \"gradient-text\"\n  ],\n  \"ai_usage\": \"Use as a ready-to-ship Wedding page. Copy the whole file; reskin by editing the :root custom properties (colors/radius/font) and replacing the content in each <section>. Sections are independent — reorder or delete freely. It composes catalog effects inline (animated gradient hero, glassmorphic sticky nav, scroll-triggered reveals, card hover-lift, a scroll-progress bar, and gradient text) so you get a premium feel with zero dependencies. Replace the gradient placeholder blocks with real <img> (add alt text). Responsive and reduced-motion safe out of the box.\"\n}\n</script>\n<style>\n*{box-sizing:border-box}html{scroll-behavior:smooth}\nbody{margin:0;background:#faf9f6;color:#1a1c22;font-family:system-ui,sans-serif;line-height:1.6;-webkit-font-smoothing:antialiased}\nimg{max-width:100%}a{color:inherit;text-decoration:none}\n.wrap{max-width:1140px;margin:0 auto;padding:0 1.3rem}\nh1,h2,h3{line-height:1.1;font-family:Georgia,'Times New Roman',serif;margin:0 0 .5rem}\nh1{font-size:clamp(2.2rem,6vw,4rem);font-weight:800}\nh2{font-size:clamp(1.7rem,3.6vw,2.6rem);font-weight:800}\np{margin:0 0 1rem}\n.grad{background:linear-gradient(120deg,#5b3ee0,#0ea5a5);-webkit-background-clip:text;background-clip:text;color:transparent}\n.eyebrow{font-size:.78rem;letter-spacing:.16em;text-transform:uppercase;font-weight:700;color:#5b3ee0}\n.muted{color:#6b7280}\n.prog{position:fixed;top:0;left:0;height:3px;width:0;background:linear-gradient(120deg,#5b3ee0,#0ea5a5);z-index:99}\nnav.bar{position:sticky;top:0;z-index:40;border-bottom:1px solid #e7e3da;background:#faf9f6e6;backdrop-filter:blur(12px)}\nnav.bar .wrap{display:flex;align-items:center;justify-content:space-between;height:64px}\n.brand{font-weight:900;font-size:1.15rem;display:flex;align-items:center;gap:.5rem}\n.brand .dot{width:22px;height:22px;border-radius:7px;background:linear-gradient(120deg,#5b3ee0,#0ea5a5);display:inline-block}\n.navlinks{display:flex;gap:1.5rem;align-items:center}\n.navlinks a{color:#6b7280;font-size:.92rem;font-weight:600}\n.navlinks a:hover{color:#1a1c22}\n.btn{display:inline-block;cursor:pointer;font-weight:700;border-radius:14px;padding:.78rem 1.5rem;border:1px solid transparent;background:linear-gradient(120deg,#5b3ee0,#0ea5a5);color:#fff;transition:transform .12s,box-shadow .12s,filter .12s;}\n.btn:hover{transform:translateY(-2px);filter:brightness(1.06);box-shadow:0 10px 24px rgba(80,60,200,.25)}\n.btn.ghost{background:transparent;color:#1a1c22;border:1px solid #e7e3da}\n.btn:focus-visible,.navlinks a:focus-visible{outline:3px solid #0ea5a5;outline-offset:2px}\n.sec{padding:clamp(3rem,7vw,5.5rem) 0}\n.sec.tint{background:#f3f1ea}\n.center{text-align:center}.lead{max-width:60ch;margin-inline:auto;font-size:1.12rem}\n.grid{display:grid;gap:1.2rem}\n.card{background:#ffffff;border:1px solid #e7e3da;border-radius:14px;padding:1.4rem;box-shadow:0 12px 34px rgba(20,20,50,.10);transition:transform .18s,box-shadow .18s}\n.card.lift:hover{transform:translateY(-7px)}\n.ph{border-radius:14px;aspect-ratio:16/10;display:block}\n.tag{display:inline-block;font-size:.75rem;padding:.2rem .6rem;border-radius:999px;background:#f3f1ea;color:#6b7280;border:1px solid #e7e3da}\n.reveal{opacity:0;transform:translateY(22px);transition:opacity .7s ease,transform .7s cubic-bezier(.2,.8,.2,1)}\n.reveal.in{opacity:1;transform:none}\n.kpi{font-size:clamp(2rem,5vw,3.2rem);font-weight:900;}\ndetails{border-top:1px solid #e7e3da;padding:1rem 0}details summary{cursor:pointer;font-weight:700;list-style:none;display:flex;justify-content:space-between}\ndetails summary::-webkit-details-marker{display:none}details[open] summary{color:#5b3ee0}\nfooter.ft{border-top:1px solid #e7e3da;background:#f3f1ea}\nfooter.ft .wrap{padding:2.4rem 1.3rem}\n.fcols{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:1.5rem}\n.fcols a{display:block;color:#6b7280;padding:.2rem 0;font-size:.9rem}\n.hero-bg{position:relative;overflow:hidden}\n.hero-bg::before{content:\"\";position:absolute;inset:-30% -10% auto;height:70vmax;background:radial-gradient(closest-side,#5b3ee040,transparent 70%),radial-gradient(closest-side,#0ea5a533,transparent 70%);background-position:30% 0,80% 10%;background-repeat:no-repeat;filter:blur(10px);animation:float 16s ease-in-out infinite;pointer-events:none}\n@keyframes float{50%{transform:translateY(40px) scale(1.05)}}\n@media(max-width:820px){.navlinks{display:none}.fcols{grid-template-columns:1fr 1fr}}\n@media(prefers-reduced-motion:reduce){*{animation:none!important;scroll-behavior:auto}.reveal{opacity:1;transform:none;transition:none}.hero-bg::before{animation:none}}\n</style>\n</head>\n<body>\n<div class=\"prog\"></div>\n<nav class=\"bar\"><div class=\"wrap\">\n    <a class=\"brand\" href=\"#\"><span class=\"dot\"></span>Mia & Sam</a>\n    <div class=\"navlinks\"><a href=\"#\">Story</a><a href=\"#\">Details</a><a href=\"#\">Registry</a><a href=\"#\">RSVP</a><a class=\"btn\" href=\"#\">RSVP</a></div>\n  </div></nav>\n<header class=\"sec hero-bg\"><div class=\"wrap center\">\n    <p class=\"eyebrow reveal\">We’re getting married!</p>\n    <h1 class=\"reveal\">Mia <span class=\"grad\">&</span> Sam</h1>\n    <p class=\"lead muted reveal\">Join us on June 21st, 2026 at Rosewood Gardens for our celebration of love.</p>\n    <div class=\"reveal\" style=\"display:flex;gap:.8rem;justify-content:center;flex-wrap:wrap;margin-top:1.4rem\">\n      <a class=\"btn\" href=\"#\">RSVP</a><a class=\"btn ghost\" href=\"#\">Our story</a>\n    </div>\n    <div class=\"ph reveal\" style=\"max-width:920px;margin:2.6rem auto 0;aspect-ratio:16/8;background:linear-gradient(135deg,#5b3ee0,#0ea5a5)\"></div>\n  </div></header>\n<section class=\"sec\"><div class=\"wrap\">\n    <div class=\"center reveal\"><p class=\"eyebrow\">How it works</p><h2>Three simple steps</h2></div>\n    <div class=\"grid reveal\" style=\"grid-template-columns:repeat(auto-fit,minmax(240px,1fr));margin-top:2rem\">\n      <div class=\"card\"><div class=\"grad kpi\" style=\"font-size:2rem\">01</div><h3>Sign up</h3><p class=\"muted\">Create your account in seconds.</p></div><div class=\"card\"><div class=\"grad kpi\" style=\"font-size:2rem\">02</div><h3>Customize</h3><p class=\"muted\">Make it yours with a few clicks.</p></div><div class=\"card\"><div class=\"grad kpi\" style=\"font-size:2rem\">03</div><h3>Launch</h3><p class=\"muted\">Go live and start growing.</p></div>\n    </div></div></section>\n<section class=\"sec\"><div class=\"wrap\">\n    <div class=\"center reveal\"><p class=\"eyebrow\">Gallery</p><h2>Selected work</h2></div>\n    <div class=\"grid reveal\" style=\"grid-template-columns:repeat(auto-fit,minmax(220px,1fr));margin-top:2rem\">\n      <div class=\"ph lift\" style=\"aspect-ratio:1;background:linear-gradient(135deg,#5b3ee0,#0ea5a5)\"></div><div class=\"ph lift\" style=\"aspect-ratio:1;background:linear-gradient(135deg,#0ea5a5,#5b3ee0)\"></div><div class=\"ph lift\" style=\"aspect-ratio:1;background:linear-gradient(135deg,#a78bfa,#22d3ee)\"></div><div class=\"ph lift\" style=\"aspect-ratio:1;background:linear-gradient(135deg,#fb7185,#fbbf24)\"></div><div class=\"ph lift\" style=\"aspect-ratio:1;background:linear-gradient(135deg,#34d399,#0ea5e9)\"></div><div class=\"ph lift\" style=\"aspect-ratio:1;background:linear-gradient(135deg,#f472b6,#a78bfa)\"></div>\n    </div></div></section>\n<section class=\"sec\"><div class=\"wrap\" style=\"max-width:760px\">\n    <div class=\"center reveal\"><p class=\"eyebrow\">FAQ</p><h2>Questions, answered</h2></div>\n    <div class=\"reveal\" style=\"margin-top:1.6rem\">\n      <details><summary>Is there a free trial?<span>+</span></summary><p class=\"muted\" style=\"margin-top:.7rem\">Yes — start free, no card required.</p></details><details><summary>Can I cancel anytime?<span>+</span></summary><p class=\"muted\" style=\"margin-top:.7rem\">Absolutely, in one click.</p></details><details><summary>Do you offer support?<span>+</span></summary><p class=\"muted\" style=\"margin-top:.7rem\">Friendly humans, around the clock.</p></details><details><summary>Is my data safe?<span>+</span></summary><p class=\"muted\" style=\"margin-top:.7rem\">Encrypted in transit and at rest.</p></details>\n    </div></div></section>\n<section class=\"sec\"><div class=\"wrap\" style=\"display:grid;grid-template-columns:1fr 1fr;gap:2rem\">\n    <div class=\"reveal\"><p class=\"eyebrow\">Contact</p><h2>Let’s talk</h2><p class=\"muted\">We usually reply within a day.</p>\n      <p class=\"muted\">✉ hello@example.com<br>☎ +1 (555) 010-2030<br>📍 100 Market St, Suite 200</p></div>\n    <form class=\"card reveal\" onsubmit=\"event.preventDefault();this.querySelector('button').textContent='Sent ✓'\" style=\"display:grid;gap:.7rem\">\n      <input placeholder=\"Name\" style=\"padding:.7rem;border-radius:14px;border:1px solid #e7e3da;background:#f3f1ea;color:#1a1c22\">\n      <input placeholder=\"Email\" style=\"padding:.7rem;border-radius:14px;border:1px solid #e7e3da;background:#f3f1ea;color:#1a1c22\">\n      <textarea placeholder=\"Message\" rows=\"4\" style=\"padding:.7rem;border-radius:14px;border:1px solid #e7e3da;background:#f3f1ea;color:#1a1c22\"></textarea>\n      <button class=\"btn\" type=\"submit\">Send message</button>\n    </form><style>@media(max-width:760px){section .wrap{grid-template-columns:1fr!important}}</style></div></section>\n<footer class=\"ft\"><div class=\"wrap\"><div class=\"fcols\">\n    <div><div class=\"brand\"><span class=\"dot\"></span>Mia & Sam</div><p class=\"muted\" style=\"margin-top:.6rem;max-width:30ch\">Join us on June 21st, 2026 at Rosewood Gardens for our celebration of love.</p></div>\n    <div><strong>Product</strong><a href=\"#\">Features</a><a href=\"#\">Pricing</a><a href=\"#\">Changelog</a></div><div><strong>Company</strong><a href=\"#\">About</a><a href=\"#\">Blog</a><a href=\"#\">Careers</a></div><div><strong>Legal</strong><a href=\"#\">Privacy</a><a href=\"#\">Terms</a><a href=\"#\">Status</a></div>\n  </div><p class=\"muted\" style=\"margin-top:1.8rem;font-size:.85rem\">© <span id=\"yr\"></span> Mia & Sam. All rights reserved.</p></div></footer>\n<script>\n(function(){\n  var bar=document.querySelector('.prog');\n  function sp(){if(!bar)return;var h=document.documentElement;var m=h.scrollHeight-h.clientHeight;bar.style.width=(m>0?(h.scrollTop/m*100):0)+'%';}\n  document.addEventListener('scroll',sp,{passive:true});sp();\n  var io=new IntersectionObserver(function(es){es.forEach(function(e){if(e.isIntersecting){e.target.classList.add('in');io.unobserve(e.target);}})},{threshold:.12});\n  document.querySelectorAll('.reveal').forEach(function(el){io.observe(el)});\n  var y=document.getElementById('yr');if(y)y.textContent=new Date().getFullYear();\n})();\n</script>\n</body>\n</html>\n"
}
