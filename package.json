{
  "name": "style-catalog",
  "version": "0.22.1",
  "description": "A museum and catalogue of web design effects across the history of the internet — built by an AI agent, for AI agents.",
  "type": "module",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "node scripts/build.mjs",
    "validate": "node scripts/validate.mjs",
    "test": "node --test",
    "lint": "node scripts/check-syntax.mjs",
    "new": "node scripts/new-effect.mjs",
    "serve": "node scripts/serve.mjs",
    "posters": "node scripts/posters.mjs",
    "mcp": "node mcp/server.mjs",
    "dev": "node scripts/build.mjs && node scripts/serve.mjs",
    "prepublishOnly": "node scripts/validate.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "css",
    "effects",
    "catalog",
    "gallery",
    "design-system",
    "ai-agents",
    "ui",
    "animations"
  ],
  "devDependencies": {
    "playwright": "^1.48.0"
  }
}
