{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://style-catalog/schema/effect-meta.schema.json",
  "title": "Effect Metadata",
  "description": "Metadata embedded in each effect specimen via <script type=\"application/json\" id=\"effect-meta\">.",
  "type": "object",
  "required": [
    "id",
    "title",
    "summary",
    "theme",
    "categories",
    "tags",
    "tech",
    "difficulty",
    "ai_usage"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "description": "Stable, unique, kebab-case identifier. Should match the file name."
    },
    "title": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "theme": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "description": "Must match the parent folder slug."
    },
    "categories": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "tech": {
      "type": "array",
      "items": { "type": "string", "enum": ["css", "js", "html", "svg", "canvas", "webgl"] },
      "minItems": 1
    },
    "era": {
      "type": "string",
      "enum": ["1990s", "2000s", "2010s", "2020s", "timeless"]
    },
    "difficulty": {
      "type": "string",
      "enum": ["beginner", "intermediate", "advanced"]
    },
    "dependencies": {
      "type": "array",
      "items": { "type": "string" }
    },
    "browser_support": { "type": "string" },
    "performance_notes": { "type": "string" },
    "accessibility_notes": { "type": "string" },
    "customization": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "description"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "default": { "type": "string" }
        }
      }
    },
    "variations": {
      "type": "array",
      "items": { "type": "string" }
    },
    "related": {
      "type": "array",
      "items": { "type": "string" }
    },
    "ai_usage": {
      "type": "string",
      "minLength": 1,
      "description": "Instructions to another AI agent: when to use this effect, how to integrate it, which knobs to turn, and pitfalls to avoid."
    }
  }
}
